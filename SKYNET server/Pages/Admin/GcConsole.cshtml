@page
@model SKYNET_server.Pages.Admin.GcConsoleModel
@{
    ViewData["Title"] = "GC Console";
}

<style>
    .gc-console-toolbar {
        display: flex;
        gap: 0.75rem;
        align-items: center;
        margin-bottom: 0.75rem;
        flex-wrap: wrap;
    }

    .gc-console-toolbar input[type="text"] {
        min-width: 220px;
        padding: 0.25rem 0.5rem;
    }

    .gc-console-wrap {
        max-height: 70vh;
        overflow-y: auto;
        border: 1px solid #444;
        border-radius: 4px;
        background: #111;
    }

    .gc-console-table {
        width: 100%;
        border-collapse: collapse;
        font-family: Consolas, monospace;
        font-size: 0.8rem;
        color: #ddd;
    }

    .gc-console-table th {
        position: sticky;
        top: 0;
        background: #222;
        text-align: left;
        padding: 0.3rem 0.5rem;
        border-bottom: 1px solid #555;
    }

    .gc-console-table td {
        padding: 0.15rem 0.5rem;
        border-bottom: 1px solid #1d1d1d;
        white-space: nowrap;
    }

    .gc-console-table td.gc-detail {
        white-space: normal;
        word-break: break-word;
    }

    .gc-kind-in { color: #7ec8ff; }
    .gc-kind-out { color: #8be98b; }
    .gc-kind-push { color: #c39bff; }
    .gc-kind-log { color: #e0e0a0; }
    .gc-kind-error { color: #ff7a7a; font-weight: bold; }
    .gc-kind-unhandled { color: #ffb45e; }

    .gc-live { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 1rem; }
    @@media (max-width: 900px) { .gc-live { grid-template-columns: 1fr; } }
    .gc-card { border: 1px solid #444; border-radius: 4px; background: #111; padding: 0.5rem 0.75rem; }
    .gc-card h2 { margin: 0 0 0.4rem; font-size: 0.85rem; color: #9fd0ff; text-transform: uppercase; letter-spacing: 0.1em; }
    .gc-card table { width: 100%; border-collapse: collapse; font-family: Consolas, monospace; font-size: 0.78rem; color: #ddd; }
    .gc-card td, .gc-card th { padding: 0.15rem 0.4rem; border-bottom: 1px solid #1d1d1d; text-align: left; white-space: nowrap; }
    .gc-on { color: #8be98b; font-weight: bold; }
    .gc-off { color: #888; }
    .gc-muted { color: #777; font-size: 0.75rem; }
</style>

<h1>Game Coordinator Console</h1>
<p>Trafico GC en vivo: mensajes entrantes (<span class="gc-kind-in">in</span>), respuestas (<span class="gc-kind-out">out</span>), push asincronos (<span class="gc-kind-push">push</span>), <code>runtime.Log</code> de Lua (<span class="gc-kind-log">log</span>), no manejados (<span class="gc-kind-unhandled">unhandled</span>) y errores (<span class="gc-kind-error">error</span>).</p>

<div class="gc-live">
    <div class="gc-card">
        <h2>Sesiones de juego <span id="liveSummary" class="gc-muted"></span></h2>
        <table>
            <thead><tr><th>SteamID</th><th>Persona</th><th>Estado</th><th>Visto</th></tr></thead>
            <tbody id="liveSessions"><tr><td colspan="4" class="gc-muted">Cargando...</td></tr></tbody>
        </table>
    </div>
    <div class="gc-card">
        <h2>Matches activos</h2>
        <div id="liveMatches" class="gc-muted">Cargando...</div>
    </div>
</div>

<div class="gc-console-toolbar">
    <label><input type="checkbox" id="gcPause" /> Pausar</label>
    <label><input type="checkbox" id="gcAutoScroll" checked /> Auto-scroll</label>
    <input type="text" id="gcFilter" placeholder="Filtrar (kind, msg, steamid, texto)..." />
    <button type="button" id="gcClear">Limpiar</button>
    <span id="gcStatus"></span>
</div>

<div class="gc-console-wrap" id="gcWrap">
    <table class="gc-console-table">
        <thead>
            <tr>
                <th>Hora</th>
                <th>Kind</th>
                <th>App</th>
                <th>SteamID</th>
                <th>Msg</th>
                <th>Bytes</th>
                <th>Detalle</th>
            </tr>
        </thead>
        <tbody id="gcRows"></tbody>
    </table>
</div>

<script>
    (function () {
        var since = 0;
        var maxRows = 1000;
        var rows = document.getElementById("gcRows");
        var wrap = document.getElementById("gcWrap");
        var pause = document.getElementById("gcPause");
        var autoScroll = document.getElementById("gcAutoScroll");
        var filter = document.getElementById("gcFilter");
        var status = document.getElementById("gcStatus");

        document.getElementById("gcClear").addEventListener("click", function () {
            rows.innerHTML = "";
        });

        filter.addEventListener("input", applyFilter);

        function applyFilter() {
            var term = filter.value.toLowerCase();
            for (var i = 0; i < rows.children.length; i++) {
                var row = rows.children[i];
                row.style.display = !term || row.textContent.toLowerCase().indexOf(term) >= 0 ? "" : "none";
            }
        }

        function addEntry(entry) {
            var tr = document.createElement("tr");
            var time = new Date(entry.timestampUtc).toLocaleTimeString();
            var cells = [
                time,
                entry.kind,
                entry.appId || "",
                entry.steamId || "",
                entry.messageType || "",
                entry.size || "",
                entry.detail || ""
            ];

            for (var i = 0; i < cells.length; i++) {
                var td = document.createElement("td");
                td.textContent = cells[i];
                if (i === 1) {
                    td.className = "gc-kind-" + entry.kind;
                }
                if (i === 6) {
                    td.className += " gc-detail";
                }
                tr.appendChild(td);
            }

            var term = filter.value.toLowerCase();
            if (term && tr.textContent.toLowerCase().indexOf(term) < 0) {
                tr.style.display = "none";
            }

            rows.appendChild(tr);
            while (rows.children.length > maxRows) {
                rows.removeChild(rows.firstChild);
            }
        }

        function poll() {
            if (pause.checked) {
                setTimeout(poll, 1000);
                return;
            }

            fetch("?handler=Entries&since=" + since, { credentials: "same-origin" })
                .then(function (response) {
                    if (!response.ok) {
                        throw new Error("HTTP " + response.status);
                    }
                    return response.json();
                })
                .then(function (data) {
                    var entries = data.entries || [];
                    for (var i = 0; i < entries.length; i++) {
                        addEntry(entries[i]);
                        if (entries[i].seq > since) {
                            since = entries[i].seq;
                        }
                    }

                    if (entries.length > 0 && autoScroll.checked) {
                        wrap.scrollTop = wrap.scrollHeight;
                    }

                    status.textContent = "";
                    setTimeout(poll, 1000);
                })
                .catch(function (err) {
                    status.textContent = "Sin conexion (" + err.message + ")";
                    setTimeout(poll, 3000);
                });
        }

        poll();
    })();

    (function () {
        var sessionsBody = document.getElementById("liveSessions");
        var summary = document.getElementById("liveSummary");
        var matchesBox = document.getElementById("liveMatches");

        function esc(s) { return String(s == null ? "" : s).replace(/[&<>]/g, function (c) { return { "&": "&amp;", "<": "&lt;", ">": "&gt;" }[c]; }); }

        function renderSessions(data) {
            summary.textContent = "(" + data.liveGameSessions + " vivas, " + data.sweepUsersOnline + " online, ventana " + data.presenceTimeoutSeconds + "s)";
            if (!data.sessions.length) {
                sessionsBody.innerHTML = '<tr><td colspan="4" class="gc-muted">Ninguna sesion de juego activa</td></tr>';
                return;
            }
            sessionsBody.innerHTML = data.sessions.map(function (s) {
                var st = s.online ? '<span class="gc-on">online</span>' : '<span class="gc-off">offline</span>';
                return "<tr><td>" + esc(s.steamId) + "</td><td>" + esc(s.persona) + "</td><td>" + st + "</td><td>" + s.lastSeenSeconds + "s</td></tr>";
            }).join("");
        }

        function renderMatches(data) {
            if (!data.matches.length) {
                matchesBox.innerHTML = '<span class="gc-muted">Sin matches recientes</span>';
                return;
            }
            matchesBox.innerHTML = data.matches.map(function (m) {
                var players = m.players.map(function (p) {
                    return "<tr><td>" + esc(p.persona || p.steamId) + "</td><td>team " + p.team + "</td><td>hero " + p.heroId + "</td><td>" + p.equippedItems + " items</td></tr>";
                }).join("");
                return '<div style="margin-bottom:0.5rem;">' +
                    '<div class="gc-muted">lobby ' + esc(m.lobbyId) + ' &middot; match ' + esc(m.matchId) + ' &middot; state ' + m.state + '/gs ' + m.gameState + ' &middot; hace ' + m.updatedSecondsAgo + 's</div>' +
                    '<table>' + players + '</table></div>';
            }).join("");
        }

        function pollLive() {
            fetch("?handler=LiveState", { credentials: "same-origin" })
                .then(function (r) { if (!r.ok) throw new Error("HTTP " + r.status); return r.json(); })
                .then(function (data) { renderSessions(data); renderMatches(data); setTimeout(pollLive, 3000); })
                .catch(function () { setTimeout(pollLive, 5000); });
        }

        pollLive();
    })();
</script>
