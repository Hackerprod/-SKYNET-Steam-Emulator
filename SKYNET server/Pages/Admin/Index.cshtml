@page "/admin"
@model SKYNET_server.Pages.Admin.IndexModel
@{
}

<div class="space-y-6">
@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    var isError = Model.StatusMessage.StartsWith("Could not") || Model.StatusMessage.StartsWith("Invalid");
    <script>showToast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StatusMessage)), '@(isError ? "error" : "success")')</script>
}

    <section class="rounded-2xl border border-skynet-border bg-skynet-card p-6">
        <p class="text-[10px] font-black uppercase tracking-[0.22em] text-skynet-accent">Admin</p>
        <div class="mt-3 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <h1 class="text-3xl font-black text-white">Local Control Panel</h1>
                <p class="mt-2 max-w-2xl text-sm text-skynet-muted">Manage web accounts, names, friends, lobbies and servers registered by the emulator.</p>
            </div>
            <div class="grid grid-cols-2 gap-2 md:grid-cols-4 xl:grid-cols-6">
                <div class="rounded-xl border border-skynet-border bg-skynet-black px-4 py-3 text-center">
                    <p class="text-2xl font-black text-white">@Model.Overview.Users.Count</p>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-skynet-muted">Users</p>
                </div>
                <div class="rounded-xl border border-skynet-border bg-skynet-black px-4 py-3 text-center">
                    <p class="text-2xl font-black text-white">@Model.Overview.Accounts.Count</p>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-skynet-muted">Accounts</p>
                </div>
                <div class="rounded-xl border border-skynet-border bg-skynet-black px-4 py-3 text-center">
                    <p class="text-2xl font-black text-white">@Model.Overview.FriendLinks</p>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-skynet-muted">Friend Links</p>
                </div>
                <div class="rounded-xl border border-skynet-border bg-skynet-black px-4 py-3 text-center">
                    <p class="text-2xl font-black text-white">@Model.Overview.PendingFriendRequests</p>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-skynet-muted">Pending</p>
                </div>
                <div class="rounded-xl border border-skynet-border bg-skynet-black px-4 py-3 text-center">
                    <p class="text-2xl font-black text-white">@Model.Overview.Lobbies.Count</p>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-skynet-muted">Lobbies</p>
                </div>
                <div class="rounded-xl border border-skynet-border bg-skynet-black px-4 py-3 text-center">
                    <p class="text-2xl font-black text-white">@Model.Overview.GameServers.Count</p>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-skynet-muted">Servers</p>
                </div>
            </div>
        </div>
    </section>

    <section class="grid gap-5 xl:grid-cols-3">
        <form method="post" asp-page-handler="CreateAccount" OnComplete="onAdminCreateAccount" class="rounded-2xl border border-skynet-border bg-skynet-card p-5">
            <h2 class="text-sm font-black uppercase tracking-widest text-white">Create Account</h2>
            <label class="mt-5 block text-[10px] font-black uppercase tracking-widest text-skynet-muted">Username</label>
            <input asp-for="CreateUsername" class="mt-2 w-full px-4 py-3 rounded-lg text-sm bg-skynet-black border border-skynet-border transition-all focus:border-skynet-accent focus:outline-none focus:shadow-[0_0_0_1px_rgba(59,130,246,0.2)] text-gray-200" placeholder="johndoe" />
            <label class="mt-4 block text-[10px] font-black uppercase tracking-widest text-skynet-muted">Password</label>
            <input asp-for="CreatePassword" type="password" class="mt-2 w-full px-4 py-3 rounded-lg text-sm bg-skynet-black border border-skynet-border transition-all focus:border-skynet-accent focus:outline-none focus:shadow-[0_0_0_1px_rgba(59,130,246,0.2)] text-gray-200" placeholder="••••••••">
            <button type="submit" class="mt-5 w-full rounded-lg bg-white text-skynet-black px-4 py-3 text-xs font-black uppercase tracking-widest hover:bg-gray-200 transition-all">Create</button>
        </form>

        <form method="post" asp-page-handler="Persona" OnComplete="onAdminRename" class="rounded-2xl border border-skynet-border bg-skynet-card p-5">
            <h2 class="text-sm font-black uppercase tracking-widest text-white">Rename</h2>
            <label asp-for="TargetSteamId" class="mt-5 block text-[10px] font-black uppercase tracking-widest text-skynet-muted">User</label>
            <select asp-for="TargetSteamId" class="mt-2 w-full skynet-select px-4 py-3 rounded-lg text-sm bg-skynet-black border border-skynet-border transition-all focus:border-skynet-accent focus:outline-none focus:shadow-[0_0_0_1px_rgba(59,130,246,0.2)] text-gray-200">
                @foreach (var user in Model.Overview.Users)
                {
                    <option value="@user.SteamId">@user.PersonaName (@user.AccountId)</option>
                }
            </select>
            <label asp-for="TargetPersonaName" class="mt-4 block text-[10px] font-black uppercase tracking-widest text-skynet-muted">New name</label>
            <input asp-for="TargetPersonaName" class="mt-2 w-full px-4 py-3 rounded-lg text-sm bg-skynet-black border border-skynet-border transition-all focus:border-skynet-accent focus:outline-none focus:shadow-[0_0_0_1px_rgba(59,130,246,0.2)] text-gray-200" placeholder="Persona name" />
            <button type="submit" class="mt-5 w-full rounded-lg bg-white text-skynet-black px-4 py-3 text-xs font-black uppercase tracking-widest hover:bg-gray-200 transition-all">Rename</button>
        </form>

        <form method="post" asp-page-handler="ResetPassword" OnComplete="onAdminResetPassword" class="rounded-2xl border border-skynet-border bg-skynet-card p-5">
            <h2 class="text-sm font-black uppercase tracking-widest text-white">Reset password</h2>
            <label asp-for="ResetTargetSteamId" class="mt-5 block text-[10px] font-black uppercase tracking-widest text-skynet-muted">User</label>
            <select asp-for="ResetTargetSteamId" class="mt-2 w-full skynet-select px-4 py-3 rounded-lg text-sm bg-skynet-black border border-skynet-border transition-all focus:border-skynet-accent focus:outline-none focus:shadow-[0_0_0_1px_rgba(59,130,246,0.2)] text-gray-200">
                @foreach (var user in Model.Overview.Users)
                {
                    <option value="@user.SteamId">@user.PersonaName (@user.AccountId)</option>
                }
            </select>
            <label asp-for="NewAdminPassword" class="mt-4 block text-[10px] font-black uppercase tracking-widest text-skynet-muted">New password</label>
            <input asp-for="NewAdminPassword" type="password" class="mt-2 w-full px-4 py-3 rounded-lg text-sm bg-skynet-black border border-skynet-border transition-all focus:border-skynet-accent focus:outline-none focus:shadow-[0_0_0_1px_rgba(59,130,246,0.2)] text-gray-200" placeholder="New password">
            <button type="submit" class="mt-5 w-full rounded-lg bg-white text-skynet-black px-4 py-3 text-xs font-black uppercase tracking-widest hover:bg-gray-200 transition-all">Reset</button>
        </form>
    </section>

    <section class="grid gap-5 xl:grid-cols-[1.4fr_1fr]">
        <div class="rounded-2xl border border-skynet-border bg-skynet-card">
            <div class="border-b border-skynet-border px-5 py-4">
                <h2 class="text-sm font-black uppercase tracking-widest text-white">Users</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-skynet-border text-sm">
                    <thead class="bg-skynet-black text-[10px] uppercase tracking-widest text-skynet-muted">
                        <tr>
                            <th class="px-4 py-3 text-left">User</th>
                            <th class="px-4 py-3 text-left">SteamID</th>
                            <th class="px-4 py-3 text-left">AccountID</th>
                            <th class="px-4 py-3 text-left">Role</th>
                            <th class="px-4 py-3 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-skynet-border">
                        @foreach (var user in Model.Overview.Users)
                        {
                            var userAccount = Model.Overview.Accounts.FirstOrDefault(a => a.SteamId == user.SteamId);
                            var isAdminUser = userAccount?.IsAdmin == true;
                            var adminCount = Model.Overview.Accounts.Count(a => a.IsAdmin);

                            <tr class="text-zinc-300 hover:bg-skynet-dark/50 transition">
                                <td class="px-4 py-3">
                                    <div class="flex items-center gap-3">
                                        <img src="/api/users/@user.SteamId/avatar" alt="" class="w-9 h-9 rounded-lg border border-skynet-border object-cover bg-skynet-black" />
                                        <span class="font-bold text-white">@user.PersonaName</span>
                                    </div>
                                </td>
                                <td class="px-4 py-3 font-mono text-xs">@user.SteamId</td>
                                <td class="px-4 py-3">@user.AccountId</td>
                                <td class="px-4 py-3">
                                    @if (isAdminUser)
                                    {
                                        <span class="rounded bg-skynet-accent/10 border border-skynet-accent/20 px-2 py-0.5 text-[10px] font-black uppercase tracking-widest text-skynet-accent">Admin</span>
                                    }
                                    else
                                    {
                                        <span class="rounded border border-skynet-border px-2 py-0.5 text-[10px] font-black uppercase tracking-widest text-skynet-muted">User</span>
                                    }
                                </td>
                                <td class="px-4 py-3">
                                    <div class="flex items-center justify-end gap-2">
                                        @if (userAccount != null)
                                        {
                                            <form method="post" asp-page-handler="ToggleAdmin" OnComplete="onAdminToggleAdmin">
                                                <input type="hidden" name="ToggleAdminSteamId" value="@user.SteamId" />
                                                <button type="submit" class="w-8 h-8 rounded-lg @(isAdminUser ? "bg-yellow-500/10 text-yellow-500 border border-yellow-500/20 hover:bg-yellow-500 hover:text-white" : "bg-skynet-accent/10 text-skynet-accent border border-skynet-accent/20 hover:bg-skynet-accent hover:text-white") flex items-center justify-center transition text-xs" title="@(isAdminUser ? "Remove admin" : "Make admin")">
                                                    <i class="fas fa-crown text-[10px]"></i>
                                                </button>
                                            </form>
                                        }
                                        <form method="post" asp-page-handler="DeleteUser" OnComplete="onAdminDeleteUser">
                                            <input type="hidden" name="DeleteSteamId" value="@user.SteamId" />
                                            <button type="button" onclick="showConfirm('Delete User','Delete @user.PersonaName? This action cannot be undone.','Delete','bg-red-500 text-white hover:bg-red-600',function(){this.closest('form').requestSubmit()}.bind(this))" class="w-8 h-8 rounded-lg bg-red-500/10 text-red-500 border border-red-500/20 flex items-center justify-center hover:bg-red-500 hover:text-white transition text-xs" title="Delete user" @(isAdminUser && adminCount <= 1 ? "disabled" : "")>
                                                <i class="fas fa-trash text-[10px]"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="space-y-5">
            <section class="rounded-2xl border border-skynet-border bg-skynet-card">
                <div class="border-b border-skynet-border px-5 py-4">
                    <h2 class="text-sm font-black uppercase tracking-widest text-white">Web accounts</h2>
                </div>
                <div class="divide-y divide-skynet-border">
                    @foreach (var account in Model.Overview.Accounts)
                    {
                        <div class="px-5 py-4" data-account-steamid="@account.SteamId">
                            <div class="flex items-center justify-between gap-3">
                                <p class="font-bold text-white">@account.Username</p>
                                <span class="rounded border border-skynet-border px-2 py-0.5 text-[10px] font-black uppercase tracking-widest @(account.IsAdmin ? "text-skynet-accent" : "text-skynet-muted")">@(account.IsAdmin ? "admin" : "user")</span>
                            </div>
                            <p class="mt-1 text-xs text-skynet-muted">@account.PersonaName | @account.SteamId</p>
                            <p class="mt-1 text-xs text-skynet-muted/60">Last login: @(account.LastLoginAt == DateTime.MinValue ? "never" : account.LastLoginAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm"))</p>
                        </div>
                    }
                </div>
            </section>

            <section class="rounded-2xl border border-skynet-border bg-skynet-card p-5">
                <div class="flex items-center justify-between mb-4">
                    <h2 class="text-sm font-black uppercase tracking-widest text-white">Runtime</h2>
                    <a asp-page="/Admin/GcConsole" class="rounded-lg bg-skynet-accent/10 text-skynet-accent border border-skynet-accent/20 px-3 py-1.5 text-[10px] font-black uppercase tracking-widest hover:bg-skynet-accent hover:text-white transition-all">GC Console</a>
                </div>
                <div class="mt-4 space-y-3 text-sm text-skynet-muted">
                    @{
                        var uptime = DateTime.UtcNow - Model.Overview.ServerStartTime;
                        var uptimeStr = uptime.TotalDays >= 1
                            ? $"{(int)uptime.TotalDays}d {uptime.Hours}h {uptime.Minutes}m"
                            : uptime.TotalHours >= 1
                                ? $"{(int)uptime.TotalHours}h {uptime.Minutes}m"
                                : $"{uptime.Minutes}m {uptime.Seconds}s";
                    }
                    <p>Uptime: <span class="text-white font-bold">@uptimeStr</span></p>
                    <p>Profiles with stats: <span class="text-white font-bold">@Model.Overview.StatsProfiles</span></p>
                    <p>Dota matches: <span class="text-white font-bold">@Model.Overview.DotaMatches.Count</span></p>
                </div>
            </section>
        </div>
    </section>

    <section class="rounded-2xl border border-skynet-border bg-skynet-card">
        <div class="border-b border-skynet-border px-5 py-4">
            <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
                <div>
                    <h2 class="text-sm font-black uppercase tracking-widest text-white">Dota Cosmetics</h2>
                    <p class="mt-1 text-xs text-skynet-muted">@Model.Overview.DotaCosmetics.LastImportStatus</p>
                </div>
                <p class="text-xs text-skynet-muted">Last import: @(Model.Overview.DotaCosmetics.LastImportAt == DateTime.MinValue ? "never" : Model.Overview.DotaCosmetics.LastImportAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm"))</p>
            </div>
        </div>

        <div class="p-5 space-y-4">
            <form method="post" asp-page-handler="ImportDotaItems" OnComplete="onDotaCatalogImport" class="flex gap-3">
                <input asp-for="DotaPath" class="h-11 flex-1 px-4 rounded-lg text-sm bg-skynet-black border border-skynet-border transition-all focus:border-skynet-accent focus:outline-none focus:shadow-[0_0_0_1px_rgba(59,130,246,0.2)] text-gray-200" placeholder="Dota 2 path" />
                <button type="submit" style="width: 9rem;" class="h-11 shrink-0 rounded-lg bg-skynet-accent px-5 text-xs font-black uppercase tracking-widest text-white hover:bg-blue-600 transition-all">Update DB</button>
            </form>
            <div>
                <label asp-for="DotaClientVersion" class="block text-[10px] font-black uppercase tracking-widest text-skynet-muted">Client Version</label>
                <div class="mt-2 flex gap-3">
                    <form method="post" asp-page-handler="SetDotaClientVersion" OnComplete="onDotaClientVersionSaved" class="flex min-w-0 flex-1 gap-3">
                        <input asp-for="DotaClientVersion" type="number" min="1" class="h-11 w-full px-4 rounded-lg text-sm bg-skynet-black border border-skynet-border font-mono transition-all focus:border-skynet-accent focus:outline-none focus:shadow-[0_0_0_1px_rgba(59,130,246,0.2)] text-gray-200" placeholder="6860" />
                        <button type="submit" style="width: 9rem;" class="h-11 shrink-0 whitespace-nowrap rounded-lg bg-skynet-accent px-5 text-xs font-black uppercase tracking-widest text-white hover:bg-blue-600 transition-all">Save Version</button>
                    </form>
                </div>
                <form method="post" asp-page-handler="AutoDetectDotaClientVersion" OnComplete="onDotaClientVersionSaved" style="width: 9rem;" class="mt-3">
                    <button type="submit" style="width: 100%;" class="h-11 whitespace-nowrap rounded-lg border border-skynet-border px-5 text-xs font-black uppercase tracking-widest text-white hover:border-skynet-accent hover:text-skynet-accent transition-all">Auto Detect</button>
                </form>
            </div>
        </div>
    </section>

    <section class="rounded-2xl border border-skynet-border bg-skynet-card">
        <div class="border-b border-skynet-border px-5 py-4">
            <h2 class="text-sm font-black uppercase tracking-widest text-white">Network / Game Server</h2>
            <p class="mt-1 text-xs text-skynet-muted">IP the dedicated server advertises to clients and how it binds. Applied live; also saved to appsettings.json. Set the advertised IP to the address every player can route to (e.g. your ZeroTier IP), not your local WiFi/LAN IP.</p>
        </div>
        <form method="post" asp-page-handler="GameServerSettings" OnComplete="onGameServerSettings" class="p-5 space-y-5">
            <div class="grid gap-4 md:grid-cols-2">
                <div>
                    <label asp-for="GsAdvertisedIp" class="block text-[10px] font-black uppercase tracking-widest text-skynet-muted">Advertised IP <span class="text-skynet-muted/60 normal-case tracking-normal">(empty = auto per client subnet)</span></label>
                    <input asp-for="GsAdvertisedIp" list="hostAddressList" autocomplete="off" class="mt-2 w-full px-4 py-3 rounded-lg text-sm bg-skynet-black border border-skynet-border font-mono transition-all focus:border-skynet-accent focus:outline-none focus:shadow-[0_0_0_1px_rgba(59,130,246,0.2)] text-gray-200" placeholder="10.0.0.1" />
                    <datalist id="hostAddressList">
                        @foreach (var addr in Model.Overview.HostAddresses)
                        {
                            <option value="@addr"></option>
                        }
                    </datalist>
                    @if (Model.Overview.HostAddresses.Count > 0)
                    {
                        <div class="mt-2 flex flex-wrap gap-2">
                            @foreach (var addr in Model.Overview.HostAddresses)
                            {
                                <button type="button" onclick="document.getElementById('GsAdvertisedIp').value='@addr'" class="rounded-md border border-skynet-border bg-skynet-black px-2 py-1 text-[11px] font-mono text-skynet-muted hover:border-skynet-accent hover:text-skynet-accent transition">@addr</button>
                            }
                        </div>
                    }
                </div>
                <div>
                    <label asp-for="GsBindIp" class="block text-[10px] font-black uppercase tracking-widest text-skynet-muted">Bind IP <span class="text-skynet-muted/60 normal-case tracking-normal">(0.0.0.0 = all interfaces)</span></label>
                    <input asp-for="GsBindIp" autocomplete="off" class="mt-2 w-full px-4 py-3 rounded-lg text-sm bg-skynet-black border border-skynet-border font-mono transition-all focus:border-skynet-accent focus:outline-none focus:shadow-[0_0_0_1px_rgba(59,130,246,0.2)] text-gray-200" placeholder="0.0.0.0" />
                    <label asp-for="GsPortStart" class="mt-4 block text-[10px] font-black uppercase tracking-widest text-skynet-muted">Port start</label>
                    <input asp-for="GsPortStart" type="number" min="1024" max="65534" class="mt-2 w-full px-4 py-3 rounded-lg text-sm bg-skynet-black border border-skynet-border font-mono transition-all focus:border-skynet-accent focus:outline-none focus:shadow-[0_0_0_1px_rgba(59,130,246,0.2)] text-gray-200" placeholder="27025" />
                </div>
            </div>
            <div class="flex flex-wrap items-center gap-6">
                <label class="flex items-center gap-2 text-sm text-skynet-muted cursor-pointer">
                    <input asp-for="GsDedicatedEnabled" class="h-4 w-4 rounded border-skynet-border bg-skynet-black text-skynet-accent focus:ring-skynet-accent" />
                    <span>Dedicated enabled</span>
                </label>
                <span class="text-xs text-skynet-muted/60">Dedicated always runs <span class="font-mono">-insecure</span> (VAC disabled) — the emulator has no valid VAC session.</span>
                <button type="submit" class="ml-auto rounded-lg bg-skynet-accent px-5 py-3 text-xs font-black uppercase tracking-widest text-white hover:bg-blue-600 transition-all">Save</button>
            </div>
        </form>
    </section>
</div>

<script>
    function onDotaCatalogImport(data) {
        if (data && data.success) {
            showToast(data.message || 'Catalog updated.', 'success');
        } else {
            showToast(data && data.message ? data.message : 'Could not update catalog.', 'error');
        }
    }
    function onDotaClientVersionSaved(data) {
        if (data && data.success) {
            var input = document.getElementById('DotaClientVersion');
            if (input && data.clientVersion) {
                input.value = data.clientVersion;
            }
            showToast(data.message || 'ClientVersion saved.', 'success');
        } else {
            showToast(data && data.message ? data.message : 'Could not save ClientVersion.', 'error');
        }
    }
    function onAdminCreateAccount(data, form) {
        if (data && data.success) {
            showToast(data.message, 'success');
            form.querySelector('input[name="CreateUsername"]').value = '';
            form.querySelector('input[name="CreatePassword"]').value = '';
        } else {
            showToast(data && data.message ? data.message : 'Could not create account.', 'error');
        }
    }
    function onAdminRename(data, form) {
        if (data && data.success) {
            showToast(data.message, 'success');
            form.querySelector('input[name="TargetPersonaName"]').value = '';
            var opt = form.querySelector('select[name="TargetSteamId"]');
            if (opt) { var name = opt.options[opt.selectedIndex].text.split(' (')[0]; form.closest('table') && location.reload(); }
        } else {
            showToast(data && data.message ? data.message : 'Could not rename.', 'error');
        }
    }
    function onAdminResetPassword(data, form) {
        if (data && data.success) {
            showToast(data.message, 'success');
            form.querySelector('input[name="NewAdminPassword"]').value = '';
        } else {
            showToast(data && data.message ? data.message : 'Could not reset password.', 'error');
        }
    }
    function onAdminToggleAdmin(data, form) {
        if (data && data.success) {
            showToast(data.message, 'success');
            var row = form.closest('tr');
            if (!row) return;
            var badge = row.querySelector('td:nth-child(4) span');
            var btn = form.querySelector('button');
            var wasAdmin = badge && badge.textContent.trim() === 'Admin';
            if (badge) {
                if (wasAdmin) {
                    badge.className = 'rounded border border-skynet-border px-2 py-0.5 text-[10px] font-black uppercase tracking-widest text-skynet-muted';
                    badge.textContent = 'User';
                } else {
                    badge.className = 'rounded bg-skynet-accent/10 border border-skynet-accent/20 px-2 py-0.5 text-[10px] font-black uppercase tracking-widest text-skynet-accent';
                    badge.textContent = 'Admin';
                }
            }
            if (btn) {
                if (wasAdmin) {
                    btn.className = 'w-8 h-8 rounded-lg bg-skynet-accent/10 text-skynet-accent border border-skynet-accent/20 hover:bg-skynet-accent hover:text-white flex items-center justify-center transition text-xs';
                    btn.title = 'Make admin';
                } else {
                    btn.className = 'w-8 h-8 rounded-lg bg-yellow-500/10 text-yellow-500 border border-yellow-500/20 hover:bg-yellow-500 hover:text-white flex items-center justify-center transition text-xs';
                    btn.title = 'Remove admin';
                }
            }
        } else {
            showToast(data && data.message ? data.message : 'Could not update admin status.', 'error');
        }
    }
    function onGameServerSettings(data, form) {
        if (data && data.success) {
            showToast(data.message || 'Game server settings saved.', 'success');
        } else {
            showToast(data && data.message ? data.message : 'Could not save settings.', 'error');
        }
    }
    function onAdminDeleteUser(data, form) {
        if (data && data.success) {
            showToast(data.message, 'success');
            var row = form.closest('tr');
            if (row) {
                var steamId = form.querySelector('input[name="DeleteSteamId"]').value;
                row.style.transition = 'opacity 0.3s, transform 0.3s';
                row.style.opacity = '0';
                row.style.transform = 'translateX(20px)';
                setTimeout(function() { row.remove(); }, 300);
                var accountEntry = document.querySelector('[data-account-steamid="' + steamId + '"]');
                if (accountEntry) {
                    accountEntry.style.transition = 'opacity 0.3s';
                    accountEntry.style.opacity = '0';
                    setTimeout(function() { accountEntry.remove(); }, 300);
                }
            }
        } else {
            showToast(data && data.message ? data.message : 'Could not delete user.', 'error');
        }
    }
</script>
