@page "/admin"
@model SKYNET_server.Pages.Admin.IndexModel
@{
    var adminAccount = Model.Overview.Accounts.FirstOrDefault(account => account.IsAdmin);
}

<div class="space-y-6">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="rounded-2xl border border-skynet-accent/30 bg-skynet-accent/10 px-5 py-3 text-sm font-bold text-blue-200">@Model.StatusMessage</div>
    }

    <section class="rounded-2xl border border-skynet-border bg-skynet-card p-6">
        <p class="text-[10px] font-black uppercase tracking-[0.22em] text-skynet-accent">Admin</p>
        <div class="mt-3 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <h1 class="text-3xl font-black text-white">Local Control Panel</h1>
                <p class="mt-2 max-w-2xl text-sm text-skynet-muted">Manage web accounts, names, friends, lobbies and servers registered by the emulator.</p>
            </div>
            <div class="grid grid-cols-2 gap-2 md:grid-cols-4 xl:grid-cols-8">
                <div class="rounded-xl border border-skynet-border bg-skynet-black px-4 py-3 text-center">
                    <p class="text-2xl font-black text-white">@Model.Overview.Users.Count</p>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-skynet-muted">Users</p>
                </div>
                <div class="rounded-xl border border-skynet-border bg-skynet-black px-4 py-3 text-center">
                    <p class="text-2xl font-black text-white">@Model.Overview.Accounts.Count</p>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-skynet-muted">Accounts</p>
                </div>
                <div class="rounded-xl border border-skynet-border bg-skynet-black px-4 py-3 text-center">
                    <p class="text-2xl font-black text-white">@Model.Overview.FriendLinks</p>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-skynet-muted">Links</p>
                </div>
                <div class="rounded-xl border border-skynet-border bg-skynet-black px-4 py-3 text-center">
                    <p class="text-2xl font-black text-white">@Model.Overview.PendingFriendRequests</p>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-skynet-muted">Pending</p>
                </div>
                <div class="rounded-xl border border-skynet-border bg-skynet-black px-4 py-3 text-center">
                    <p class="text-2xl font-black text-white">@Model.Overview.Lobbies.Count</p>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-skynet-muted">Lobbies</p>
                </div>
                <div class="rounded-xl border border-skynet-border bg-skynet-black px-4 py-3 text-center">
                    <p class="text-2xl font-black text-white">@Model.Overview.GameServers.Count</p>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-skynet-muted">Servers</p>
                </div>
                <div class="rounded-xl border border-skynet-border bg-skynet-black px-4 py-3 text-center">
                    <p class="text-2xl font-black text-white">@Model.Overview.DotaCosmetics.ItemCount</p>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-skynet-muted">Items</p>
                </div>
                <div class="rounded-xl border border-skynet-border bg-skynet-black px-4 py-3 text-center">
                    <p class="text-2xl font-black text-white">@Model.Overview.DotaCosmetics.EquippedCount</p>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-skynet-muted">Equipped</p>
                </div>
            </div>
        </div>
    </section>

    <section class="grid gap-5 xl:grid-cols-3">
        <form method="post" asp-page-handler="Credentials" class="rounded-2xl border border-skynet-border bg-skynet-card p-5">
            <h2 class="text-sm font-black uppercase tracking-widest text-white">Admin credentials</h2>
            <p class="mt-1 text-xs text-skynet-muted">Current admin: @(adminAccount?.Username ?? "none")</p>
            <label asp-for="AdminUsername" class="mt-5 block text-[10px] font-black uppercase tracking-widest text-skynet-muted">Username</label>
            <input asp-for="AdminUsername" class="mt-2 w-full rounded-lg border border-skynet-border bg-skynet-black text-sm text-white focus:border-skynet-accent focus:ring-skynet-accent" />
            <label asp-for="CurrentAdminPassword" class="mt-4 block text-[10px] font-black uppercase tracking-widest text-skynet-muted">Current password</label>
            <input asp-for="CurrentAdminPassword" type="password" class="mt-2 w-full rounded-lg border border-skynet-border bg-skynet-black text-sm text-white focus:border-skynet-accent focus:ring-skynet-accent" />
            <label asp-for="NewAdminPassword" class="mt-4 block text-[10px] font-black uppercase tracking-widest text-skynet-muted">New password</label>
            <input asp-for="NewAdminPassword" type="password" class="mt-2 w-full rounded-lg border border-skynet-border bg-skynet-black text-sm text-white focus:border-skynet-accent focus:ring-skynet-accent" placeholder="Leave empty to keep unchanged" />
            <button type="submit" class="mt-5 w-full rounded-lg bg-white text-skynet-black px-4 py-3 text-xs font-black uppercase tracking-widest hover:bg-gray-200 transition-all">Save</button>
        </form>

        <form method="post" asp-page-handler="Persona" class="rounded-2xl border border-skynet-border bg-skynet-card p-5">
            <h2 class="text-sm font-black uppercase tracking-widest text-white">Rename</h2>
            <label asp-for="TargetSteamId" class="mt-5 block text-[10px] font-black uppercase tracking-widest text-skynet-muted">User</label>
            <select asp-for="TargetSteamId" class="mt-2 w-full rounded-lg border border-skynet-border bg-skynet-black text-sm text-white focus:border-skynet-accent focus:ring-skynet-accent">
                @foreach (var user in Model.Overview.Users)
                {
                    <option value="@user.SteamId">@user.PersonaName (@user.AccountId)</option>
                }
            </select>
            <label asp-for="TargetPersonaName" class="mt-4 block text-[10px] font-black uppercase tracking-widest text-skynet-muted">New name</label>
            <input asp-for="TargetPersonaName" class="mt-2 w-full rounded-lg border border-skynet-border bg-skynet-black text-sm text-white focus:border-skynet-accent focus:ring-skynet-accent" placeholder="Persona name" />
            <button type="submit" class="mt-5 w-full rounded-lg bg-white text-skynet-black px-4 py-3 text-xs font-black uppercase tracking-widest hover:bg-gray-200 transition-all">Rename</button>
        </form>

        <div class="rounded-2xl border border-skynet-border bg-skynet-card p-5">
            <h2 class="text-sm font-black uppercase tracking-widest text-white">Friendships</h2>
            <form method="post" asp-page-handler="Link" class="mt-5 space-y-4">
                <select asp-for="LeftSteamId" class="w-full rounded-lg border border-skynet-border bg-skynet-black text-sm text-white focus:border-skynet-accent focus:ring-skynet-accent">
                    @foreach (var user in Model.Overview.Users)
                    {
                        <option value="@user.SteamId">@user.PersonaName (@user.AccountId)</option>
                    }
                </select>
                <select asp-for="RightSteamId" class="w-full rounded-lg border border-skynet-border bg-skynet-black text-sm text-white focus:border-skynet-accent focus:ring-skynet-accent">
                    @foreach (var user in Model.Overview.Users)
                    {
                        <option value="@user.SteamId">@user.PersonaName (@user.AccountId)</option>
                    }
                </select>
                <div class="grid grid-cols-2 gap-2">
                    <button type="submit" class="rounded-lg bg-skynet-accent px-4 py-3 text-xs font-black uppercase tracking-widest text-white hover:bg-blue-600 transition-all">Link</button>
                    <button type="submit" formaction="?handler=Unlink" class="rounded-lg border border-red-500/30 px-4 py-3 text-xs font-black uppercase tracking-widest text-red-300 hover:bg-red-500/10 transition-all">Unlink</button>
                </div>
            </form>
        </div>
    </section>

    <section class="grid gap-5 xl:grid-cols-[1.4fr_1fr]">
        <div class="rounded-2xl border border-skynet-border bg-skynet-card">
            <div class="border-b border-skynet-border px-5 py-4">
                <h2 class="text-sm font-black uppercase tracking-widest text-white">Users</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-skynet-border text-sm">
                    <thead class="bg-skynet-black text-[10px] uppercase tracking-widest text-skynet-muted">
                        <tr>
                            <th class="px-4 py-3 text-left">Name</th>
                            <th class="px-4 py-3 text-left">SteamID</th>
                            <th class="px-4 py-3 text-left">AccountID</th>
                            <th class="px-4 py-3 text-left">App</th>
                            <th class="px-4 py-3 text-left">Lobby</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-skynet-border">
                        @foreach (var user in Model.Overview.Users)
                        {
                            <tr class="text-zinc-300">
                                <td class="px-4 py-3 font-bold text-white">@user.PersonaName</td>
                                <td class="px-4 py-3 font-mono text-xs">@user.SteamId</td>
                                <td class="px-4 py-3">@user.AccountId</td>
                                <td class="px-4 py-3">@user.AppId</td>
                                <td class="px-4 py-3">@user.LobbyId</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="space-y-5">
            <section class="rounded-2xl border border-skynet-border bg-skynet-card">
                <div class="border-b border-skynet-border px-5 py-4">
                    <h2 class="text-sm font-black uppercase tracking-widest text-white">Web accounts</h2>
                </div>
                <div class="divide-y divide-skynet-border">
                    @foreach (var account in Model.Overview.Accounts)
                    {
                        <div class="px-5 py-4">
                            <div class="flex items-center justify-between gap-3">
                                <p class="font-bold text-white">@account.Username</p>
                                <span class="rounded border border-skynet-border px-2 py-0.5 text-[10px] font-black uppercase tracking-widest @(account.IsAdmin ? "text-skynet-accent" : "text-skynet-muted")">@(account.IsAdmin ? "admin" : "user")</span>
                            </div>
                            <p class="mt-1 text-xs text-skynet-muted">@account.PersonaName | @account.SteamId</p>
                            <p class="mt-1 text-xs text-skynet-muted/60">Last login: @(account.LastLoginAt == DateTime.MinValue ? "never" : account.LastLoginAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm"))</p>
                        </div>
                    }
                </div>
            </section>

            <section class="rounded-2xl border border-skynet-border bg-skynet-card p-5">
                <h2 class="text-sm font-black uppercase tracking-widest text-white">Runtime</h2>
                <div class="mt-4 space-y-3 text-sm text-skynet-muted">
                    <p>Active lobbies: @Model.Overview.Lobbies.Count</p>
                    <p>Registered servers: @Model.Overview.GameServers.Count</p>
                    <p>Profiles with stats: @Model.Overview.StatsProfiles</p>
                </div>
            </section>
        </div>
    </section>

    <section class="rounded-2xl border border-skynet-border bg-skynet-card">
        <div class="border-b border-skynet-border px-5 py-4">
            <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
                <div>
                    <h2 class="text-sm font-black uppercase tracking-widest text-white">Dota Cosmetics</h2>
                    <p class="mt-1 text-xs text-skynet-muted">@Model.Overview.DotaCosmetics.LastImportStatus</p>
                </div>
                <p class="text-xs text-skynet-muted">Last import: @(Model.Overview.DotaCosmetics.LastImportAt == DateTime.MinValue ? "never" : Model.Overview.DotaCosmetics.LastImportAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm"))</p>
            </div>
        </div>

        <div class="p-5">
            <form method="post" asp-page-handler="ImportDotaItems" class="grid gap-3 lg:grid-cols-[1fr_auto]">
                <input asp-for="DotaPath" class="rounded-lg border border-skynet-border bg-skynet-black text-sm text-white focus:border-skynet-accent focus:ring-skynet-accent" placeholder="Dota 2 path" />
                <button type="submit" class="rounded-lg bg-skynet-accent px-5 py-3 text-xs font-black uppercase tracking-widest text-white hover:bg-blue-600 transition-all">Update DB</button>
            </form>
        </div>
    </section>
</div>
