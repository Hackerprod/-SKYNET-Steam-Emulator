@page "/friends"
@model SKYNET_server.Pages.Friends.IndexModel
@{
    var inGameCount = Model.Friends.Count(friend => friend.Status == "In game");
    var onlineCount = Model.Friends.Count(friend => friend.Status == "Online");
    var awayCount = Model.Friends.Count(friend => friend.Status == "Away");
    var squadLead = Model.Friends.FirstOrDefault(friend => friend.Status == "In game");
}

<div class="space-y-8">
    <div class="grid gap-6 lg:grid-cols-[1.5fr_1fr]">
        <header class="relative overflow-hidden rounded-2xl border border-zinc-800/60 bg-zinc-900/40 p-8 shadow-2xl shadow-black/50">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(6,182,212,0.1),transparent_70%)] z-0"></div>
            <div class="relative z-10 space-y-4">
                <span class="text-[10px] px-2.5 py-1 rounded-full font-black bg-cyan-500/10 text-cyan-500 border border-cyan-500/30 uppercase tracking-[0.2em]">Social Graph</span>
                <h1 class="text-4xl font-black text-white leading-tight">Presence and Squads.</h1>
                <p class="max-w-2xl text-zinc-400 text-sm leading-relaxed">Manage your contact network, view real-time statuses and coordinate group games with the direct invitation system.</p>

                <div class="grid grid-cols-3 gap-4 mt-8">
                    <div class="p-4 rounded-xl bg-zinc-950/60 border border-zinc-800/60 text-center">
                        <p class="text-[9px] font-black text-green-500 uppercase tracking-widest mb-1">In Game</p>
                        <p class="text-3xl font-black text-white">@inGameCount</p>
                    </div>
                    <div class="p-4 rounded-xl bg-zinc-950/60 border border-zinc-800/60 text-center">
                        <p class="text-[9px] font-black text-cyan-500 uppercase tracking-widest mb-1">Online</p>
                        <p class="text-3xl font-black text-white">@onlineCount</p>
                    </div>
                    <div class="p-4 rounded-xl bg-zinc-950/60 border border-zinc-800/60 text-center">
                        <p class="text-[9px] font-black text-amber-500 uppercase tracking-widest mb-1">Away</p>
                        <p class="text-3xl font-black text-white">@awayCount</p>
                    </div>
                </div>
            </div>
        </header>

        <aside class="relative overflow-hidden rounded-2xl border border-zinc-800/60 bg-gradient-to-br from-cyan-500/10 via-zinc-950 to-purple-500/10 p-8 flex flex-col justify-center">
            <div class="relative z-10">
                <span class="text-[10px] font-black text-zinc-500 uppercase tracking-widest mb-2 block">Party Status</span>
                <h2 class="text-2xl font-black text-white mb-3">Squad ready to enter</h2>
                <p class="text-sm text-zinc-400 leading-relaxed">
                    @(squadLead is null ? "There is no active squad at this time." : $"{squadLead.DisplayName} keeps the party active in {squadLead.CurrentGame}.")
                </p>
                <button class="mt-8 w-full py-4 rounded-xl text-[10px] font-black uppercase tracking-widest bg-gradient-to-br from-cyan-500 to-purple-500 text-white shadow-glow-cyan hover:scale-[1.02] transition-transform">
                    Open Party Panel
                </button>
            </div>
        </aside>
    </div>

    <div class="grid gap-6 xl:grid-cols-[1.5fr_1fr]">
        <div class="space-y-3">
            <div class="flex items-center justify-between mb-4 px-2">
                <h3 class="text-xs font-black text-zinc-500 uppercase tracking-widest">Contact List</h3>
                <span class="text-[10px] font-bold text-cyan-500">@Model.Friends.Count Contacts</span>
            </div>
            
            @foreach (var friend in Model.Friends)
            {
                <article class="group flex flex-col md:flex-row md:items-center justify-between gap-4 p-5 rounded-2xl border border-zinc-800/60 bg-zinc-900/60 hover:border-zinc-700/60 transition-all">
                    <div class="flex items-center gap-4">
                        <div class="relative">
                            <div class="w-14 h-14 rounded-full bg-zinc-800 border-2 border-zinc-700 flex items-center justify-center text-sm font-black text-white group-hover:border-cyan-500/50 transition-colors">
                                @friend.Initials
                            </div>
                            <span class="absolute bottom-0 right-0 w-4 h-4 rounded-full border-2 border-zinc-900 @(friend.Status == "In game" ? "bg-green-500 shadow-[0_0_10px_rgba(34,197,94,0.5)]" : friend.Status == "Online" ? "bg-cyan-500 shadow-[0_0_10px_rgba(6,182,212,0.5)]" : "bg-amber-500")"></span>
                        </div>
                        <div class="min-w-0">
                            <div class="flex items-center gap-2">
                                <h3 class="text-lg font-black text-white truncate">@friend.DisplayName</h3>
                            </div>
                            <p class="text-xs font-bold text-cyan-500 mt-0.5">@friend.CurrentGame</p>
                            <p class="text-[10px] text-zinc-500 mt-1 italic">@friend.Note</p>
                        </div>
                    </div>
                    <div class="flex gap-2">
                        <button class="flex-1 md:flex-none px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest bg-cyan-500/10 text-cyan-500 border border-cyan-500/30 hover:bg-cyan-500/20 transition-colors">
                            Invite
                        </button>
                        <button class="flex-1 md:flex-none px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest bg-zinc-800/60 text-zinc-400 border border-zinc-700/40 hover:text-white transition-colors">
                            Chat
                        </button>
                    </div>
                </article>
            }
        </div>

        <aside class="space-y-6">
            <section class="rounded-2xl border border-zinc-800/60 bg-zinc-900/80 p-6">
                <h3 class="text-xs font-black text-zinc-500 uppercase tracking-widest mb-6">Overlay Preview</h3>
                <div class="space-y-4">
                    <div class="p-4 rounded-xl bg-zinc-950/40 border border-zinc-800/60 group hover:border-cyan-500/30 transition-colors">
                        <p class="text-sm font-black text-white">Quick Chat</p>
                        <p class="text-[11px] text-zinc-500 mt-2 leading-relaxed">Compact cards with status, current game and direct invitation buttons.</p>
                    </div>
                    <div class="p-4 rounded-xl bg-zinc-950/40 border border-zinc-800/60 group hover:border-cyan-500/30 transition-colors">
                        <p class="text-sm font-black text-white">Active Presence</p>
                        <p class="text-[11px] text-zinc-500 mt-2 leading-relaxed">Visual signal by status through glow rings for In-Game and Online.</p>
                    </div>
                    <div class="p-4 rounded-xl bg-zinc-950/40 border border-zinc-800/60 group hover:border-cyan-500/30 transition-colors">
                        <p class="text-sm font-black text-white">Voice Hooks</p>
                        <p class="text-[11px] text-zinc-500 mt-2 leading-relaxed">Planned space for voice indicators, party status and push notifications.</p>
                    </div>
                </div>
            </section>
        </aside>
    </div>
</div>
