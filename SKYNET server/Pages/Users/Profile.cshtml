@page "/users/{steamId}"
@model SKYNET_server.Pages.Users.ProfileModel
@{
    var user = Model.Profile.User;
    var stats = Model.Profile.Stats;
    var relationship = Model.Profile.FriendRelationship;
    var relationLabel = relationship switch
    {
        2 => "Solicitud recibida",
        3 => "Amigo",
        4 => "Solicitud enviada",
        _ => Model.Profile.IsSelf ? "Tu perfil" : "Sin relacion"
    };
}

<div class="space-y-6">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="rounded-lg border border-cyan-500/30 bg-cyan-500/10 px-4 py-3 text-sm font-bold text-cyan-100">@Model.StatusMessage</div>
    }

    <section class="rounded-lg border border-zinc-800 bg-zinc-900/70 p-6">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
            <div class="flex min-w-0 items-start gap-5">
                <img src="/api/users/@user.SteamId/avatar" alt="" class="h-24 w-24 shrink-0 rounded-lg border border-zinc-700 bg-zinc-950 object-cover" />
                <div class="min-w-0">
                    <p class="text-[10px] font-black uppercase tracking-[0.22em] text-cyan-400">Perfil</p>
                    <h1 class="mt-2 truncate text-3xl font-black text-white">@user.PersonaName</h1>
                    <p class="mt-2 text-sm text-zinc-400">SteamID @user.SteamId</p>
                    <p class="mt-1 text-sm text-zinc-400">AccountID @user.AccountId - App @user.AppId</p>
                    <div class="mt-4 flex flex-wrap gap-2">
                        <span class="rounded border border-zinc-700 px-3 py-1 text-[10px] font-black uppercase tracking-widest text-zinc-300">@relationLabel</span>
                        <span class="rounded border border-zinc-700 px-3 py-1 text-[10px] font-black uppercase tracking-widest text-cyan-400">Nivel @user.PlayerLevel</span>
                    </div>
                </div>
            </div>

            @if (!Model.Profile.IsSelf)
            {
                <div class="flex flex-wrap gap-2">
                    @if (relationship == 0)
                    {
                        <form method="post" asp-page-handler="Request">
                            <input type="hidden" asp-for="SteamId" value="@user.SteamId" />
                            <button class="rounded-lg bg-cyan-600 px-4 py-3 text-xs font-black uppercase tracking-widest text-white hover:bg-cyan-500">Agregar amigo</button>
                        </form>
                    }
                    else if (relationship == 2)
                    {
                        <form method="post" asp-page-handler="Accept">
                            <input type="hidden" asp-for="SteamId" value="@user.SteamId" />
                            <button class="rounded-lg bg-cyan-600 px-4 py-3 text-xs font-black uppercase tracking-widest text-white hover:bg-cyan-500">Aceptar solicitud</button>
                        </form>
                    }
                    @if (relationship == 2 || relationship == 3 || relationship == 4)
                    {
                        <form method="post" asp-page-handler="Remove">
                            <input type="hidden" asp-for="SteamId" value="@user.SteamId" />
                            <button class="rounded-lg border border-red-500/30 px-4 py-3 text-xs font-black uppercase tracking-widest text-red-300 hover:bg-red-500/10">Quitar</button>
                        </form>
                    }
                </div>
            }
        </div>
    </section>

    <section class="grid gap-5 xl:grid-cols-[1fr_0.8fr]">
        <div class="rounded-lg border border-zinc-800 bg-zinc-900">
            <div class="border-b border-zinc-800 px-5 py-4">
                <h2 class="text-lg font-black text-white">Stats</h2>
                <p class="text-xs text-zinc-500">Valores guardados en el backend para este usuario.</p>
            </div>
            <div class="divide-y divide-zinc-800">
                @if (stats.Stats.Count == 0)
                {
                    <p class="px-5 py-6 text-sm text-zinc-500">No hay stats guardados.</p>
                }
                @foreach (var stat in stats.Stats.OrderBy(stat => stat.Name))
                {
                    <div class="flex items-center justify-between px-5 py-3">
                        <span class="text-sm font-semibold text-zinc-200">@stat.Name</span>
                        <span class="font-mono text-sm text-cyan-300">@stat.Data</span>
                    </div>
                }
            </div>
        </div>

        <div class="rounded-lg border border-zinc-800 bg-zinc-900">
            <div class="border-b border-zinc-800 px-5 py-4">
                <h2 class="text-lg font-black text-white">Achievements</h2>
                <p class="text-xs text-zinc-500">Resumen de progreso persistido.</p>
            </div>
            <div class="divide-y divide-zinc-800">
                @if (stats.Achievements.Count == 0)
                {
                    <p class="px-5 py-6 text-sm text-zinc-500">No hay achievements guardados.</p>
                }
                @foreach (var achievement in stats.Achievements.OrderBy(achievement => achievement.Name))
                {
                    var progress = achievement.MaxProgress == 0 ? (achievement.Earned ? 100 : 0) : (int)Math.Min(100, (achievement.Progress * 100UL) / achievement.MaxProgress);
                    <div class="px-5 py-4">
                        <div class="flex items-center justify-between gap-3">
                            <p class="truncate text-sm font-bold text-white">@achievement.Name</p>
                            <span class="rounded border border-zinc-700 px-2 py-0.5 text-[10px] font-black uppercase tracking-widest @(achievement.Earned ? "text-cyan-400" : "text-zinc-500")">@(achievement.Earned ? "OK" : "LOCK")</span>
                        </div>
                        <div class="mt-3 h-1.5 rounded bg-zinc-800">
                            <div class="h-1.5 rounded bg-cyan-500" style="width:@progress%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
</div>
