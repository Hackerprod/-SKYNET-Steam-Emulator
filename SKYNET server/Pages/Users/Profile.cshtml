@page "/users/{steamId}"
@model SKYNET_server.Pages.Users.ProfileModel
@{
    var user = Model.Profile.User;
    var stats = Model.Profile.Stats;
    var relationship = Model.Profile.FriendRelationship;
    var isSelf = Model.Profile.IsSelf;
    var achievementUnlocked = stats.Achievements.Count(a => a.Earned);
    var achievementTotal = stats.Achievements.Count;
    var totalStats = stats.Stats.Sum(s => s.Data);
}

<div class="space-y-6">
@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    var isError = Model.StatusMessage.StartsWith("Could not") || Model.StatusMessage.StartsWith("Invalid");
    <script>showToast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StatusMessage)), '@(isError ? "error" : "success")')</script>
}

    <!-- Profile Hero -->
    <section class="relative overflow-hidden rounded-2xl border border-skynet-border bg-skynet-card">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(59,130,246,0.06),transparent_70%)]"></div>
        <div class="relative z-10 p-8 flex flex-col md:flex-row items-center gap-8">
            <div class="relative">
                <img src="/api/users/@user.SteamId/avatar" alt="" class="w-28 h-28 rounded-2xl border-2 border-skynet-border object-cover bg-skynet-black" />
                <div class="absolute -bottom-2 -right-2 w-8 h-8 rounded-full bg-skynet-card border-2 border-skynet-border flex items-center justify-center">
                    <div class="w-3 h-3 rounded-full @(user.PersonaState != 0 ? "bg-green-500" : "bg-gray-500")"></div>
                </div>
            </div>

            <div class="flex-1 text-center md:text-left min-w-0">
                <div class="flex items-center justify-center md:justify-start gap-3">
                    <h1 class="text-3xl font-black text-white truncate">@user.PersonaName</h1>
                </div>
                <p class="text-sm text-skynet-muted mt-1">SteamID @user.SteamId &middot; Account @user.AccountId</p>
                <div class="flex flex-wrap justify-center md:justify-start gap-3 mt-4">
                    <span class="inline-flex items-center gap-1.5 rounded-lg bg-skynet-black/60 border border-skynet-border px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest @(user.PersonaState != 0 ? "text-green-500" : "text-skynet-muted")">
                        <i class="fas fa-circle text-[6px]"></i> @(user.PersonaState != 0 ? "Online" : "Offline")
                    </span>
                    <span class="inline-flex items-center gap-1.5 rounded-lg bg-skynet-black/60 border border-skynet-border px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest text-skynet-accent">
                        <i class="fas fa-layer-group text-[8px]"></i> Level @user.PlayerLevel
                    </span>
                    @if (user.AppId > 0)
                    {
                        <span class="inline-flex items-center gap-1.5 rounded-lg bg-skynet-black/60 border border-skynet-border px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest text-skynet-muted">
                            <i class="fas fa-gamepad text-[8px]"></i> App @user.AppId
                        </span>
                    }
                    <span class="inline-flex items-center gap-1.5 rounded-lg bg-skynet-black/60 border border-skynet-border px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest text-skynet-muted">
                        @(relationship switch { 2 => "Request received", 3 => "Friend", 4 => "Request sent", _ => isSelf ? "Your profile" : "Not connected" })
                    </span>
                </div>
            </div>

            @if (!isSelf)
            {
                <div class="flex gap-2 shrink-0">
                    @if (relationship == 0)
                    {
                        <form method="post" asp-page-handler="Request" OnComplete="onProfileRelation">
                            <input type="hidden" asp-for="SteamId" value="@user.SteamId" />
                            <button class="rounded-lg bg-skynet-accent px-5 py-3 text-xs font-black uppercase tracking-widest text-white hover:bg-blue-600 transition-all"><i class="fas fa-user-plus mr-2"></i>Add Friend</button>
                        </form>
                    }
                    else if (relationship == 2)
                    {
                        <form method="post" asp-page-handler="Accept" OnComplete="onProfileRelation">
                            <input type="hidden" asp-for="SteamId" value="@user.SteamId" />
                            <button class="rounded-lg bg-skynet-accent px-5 py-3 text-xs font-black uppercase tracking-widest text-white hover:bg-blue-600 transition-all"><i class="fas fa-user-check mr-2"></i>Accept</button>
                        </form>
                    }
                    @if (relationship == 2 || relationship == 3 || relationship == 4)
                    {
                        <form method="post" asp-page-handler="Remove" OnComplete="onProfileRelation">
                            <input type="hidden" asp-for="SteamId" value="@user.SteamId" />
                            <button class="rounded-lg border border-red-500/30 px-5 py-3 text-xs font-black uppercase tracking-widest text-red-300 hover:bg-red-500/10 transition-all"><i class="fas fa-user-minus mr-2"></i>Remove</button>
                        </form>
                    }
                </div>
            }
        </div>
    </section>

    <!-- Stats + Achievements -->
    <section class="grid gap-5 xl:grid-cols-[1fr_0.8fr]">
        <!-- Stats -->
        <div class="rounded-2xl border border-skynet-border bg-skynet-card">
            <div class="border-b border-skynet-border px-5 py-4">
                <h2 class="text-sm font-black uppercase tracking-widest text-white">Stats</h2>
                <p class="text-xs text-skynet-muted mt-1">Backend persisted values.</p>
            </div>
            @if (stats.Stats.Count == 0)
            {
                <p class="px-5 py-6 text-sm text-skynet-muted">No saved stats.</p>
            }
            else
            {
                <div class="grid grid-cols-2 gap-px bg-skynet-border">
                    @foreach (var stat in stats.Stats.OrderBy(s => s.Name))
                    {
                        <div class="bg-skynet-card p-4 text-center">
                            <p class="text-2xl font-black text-skynet-accent">@stat.Data.ToString("N0")</p>
                            <p class="text-[10px] font-bold uppercase tracking-widest text-skynet-muted mt-1">@stat.Name</p>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Achievements -->
        <div class="rounded-2xl border border-skynet-border bg-skynet-card">
            <div class="border-b border-skynet-border px-5 py-4 flex items-center justify-between">
                <h2 class="text-sm font-black uppercase tracking-widest text-white">Achievements</h2>
                @if (achievementTotal > 0)
                {
                    <span class="text-[10px] font-bold uppercase tracking-widest text-skynet-accent">@achievementUnlocked / @achievementTotal</span>
                }
            </div>
            @if (stats.Achievements.Count == 0)
            {
                <p class="px-5 py-6 text-sm text-skynet-muted">No saved achievements.</p>
            }
            else
            {
                <div class="divide-y divide-skynet-border">
                    @foreach (var achievement in stats.Achievements.OrderByDescending(a => a.Earned).ThenByDescending(a => a.Progress).Take(8))
                    {
                        var progress = achievement.MaxProgress == 0 ? (achievement.Earned ? 100 : 0) : (int)Math.Min(100, (achievement.Progress * 100UL) / achievement.MaxProgress);
                        <div class="px-5 py-3">
                            <div class="flex items-center justify-between gap-3">
                                <p class="truncate text-sm font-bold text-white">@achievement.Name</p>
                                <span class="shrink-0 rounded px-2 py-0.5 text-[10px] font-black uppercase @(achievement.Earned ? "bg-skynet-accent/10 text-skynet-accent border border-skynet-accent/20" : "text-skynet-muted border border-skynet-border")">@(achievement.Earned ? "OK" : "LOCK")</span>
                            </div>
                            @if (!achievement.Earned && achievement.MaxProgress > 0)
                            {
                                <div class="mt-2 h-1 rounded bg-skynet-dark overflow-hidden">
                                    <div class="h-full rounded bg-skynet-accent" style="width:@progress%"></div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </section>
</div>

<script>
    function onProfileRelation(data, form) {
        if (data && data.success) {
            showToast(data.message, 'success');
            var container = form.parentElement;
            var steamId = form.querySelector('input[name="SteamId"]').value;
            var action = form.getAttribute('asp-page-handler') || '';
            var pageUrl = window.location.pathname;
            if (action === 'Request') {
                container.innerHTML =
                    '<form method="post" action="' + pageUrl + '?handler=Remove"><input type="hidden" name="SteamId" value="' + steamId + '" />' +
                    '<button class="rounded-lg border border-red-500/30 px-5 py-3 text-xs font-black uppercase tracking-widest text-red-300 hover:bg-red-500/10 transition-all"><i class="fas fa-user-minus mr-2"></i>Remove</button></form>';
            } else if (action === 'Accept') {
                container.innerHTML =
                    '<form method="post" action="' + pageUrl + '?handler=Remove"><input type="hidden" name="SteamId" value="' + steamId + '" />' +
                    '<button class="rounded-lg border border-red-500/30 px-5 py-3 text-xs font-black uppercase tracking-widest text-red-300 hover:bg-red-500/10 transition-all"><i class="fas fa-user-minus mr-2"></i>Remove</button></form>';
            } else if (action === 'Remove') {
                container.innerHTML =
                    '<form method="post" action="' + pageUrl + '?handler=Request"><input type="hidden" name="SteamId" value="' + steamId + '" />' +
                    '<button class="rounded-lg bg-skynet-accent px-5 py-3 text-xs font-black uppercase tracking-widest text-white hover:bg-blue-600 transition-all"><i class="fas fa-user-plus mr-2"></i>Add Friend</button></form>';
            }
            var badges = document.querySelectorAll('.flex-wrap span:last-child');
            if (badges.length > 0) {
                var statusBadge = badges[0];
                var labels = { Request: 'Request sent', Accept: 'Friend', Remove: 'Not connected' };
                statusBadge.textContent = labels[action] || statusBadge.textContent;
            }
        } else {
            showToast(data && data.message ? data.message : 'Action failed.', 'error');
        }
    }
</script>
