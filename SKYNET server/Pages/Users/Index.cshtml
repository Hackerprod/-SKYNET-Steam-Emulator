@page "/users"
@model SKYNET_server.Pages.Users.IndexModel

<div class="space-y-6">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="rounded-2xl border border-skynet-accent/30 bg-skynet-accent/10 px-5 py-3 text-sm font-bold text-blue-200">@Model.StatusMessage</div>
    }

    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h1 class="text-3xl font-bold tracking-tight">User Network</h1>
            <p class="text-skynet-muted mt-1">Connect with other active agents on the SKYNET network.</p>
        </div>
        <div class="relative w-full md:w-80">
            <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-skynet-muted text-xs"></i>
            <input type="text" id="userSearch" class="w-full bg-skynet-card border border-skynet-border rounded-lg py-2 pl-10 pr-4 text-sm focus:border-skynet-accent outline-none transition text-gray-200" placeholder="Search by username or ID..." oninput="filterUsers(this.value)">
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @if (Model.Users.Count == 0)
        {
            <div class="bg-skynet-card border border-skynet-border rounded-xl p-6">
                <h2 class="font-bold">No other users</h2>
                <p class="text-[10px] text-skynet-muted uppercase tracking-widest mt-1">Register another web account or launch Dota with a different AccountID.</p>
            </div>
        }
        @foreach (var user in Model.Users)
        {
            var isOnline = user.PersonaState != 0;
            var isFriend = user.FriendRelationship == 3;
            var isIncoming = user.FriendRelationship == 2;
            var isOutgoing = user.FriendRelationship == 4;

            string statusDotColor = isOnline ? "bg-green-500" : "bg-gray-500";
            string statusText = isOnline ? "Online" : "Offline";

            <article data-user="@user.PersonaName @user.SteamId @user.AccountId" class="bg-skynet-card border border-skynet-border rounded-xl p-6 flex items-center space-x-4 hover:bg-skynet-dark transition group">
                <div class="relative">
                    <img src="/api/users/@user.SteamId/avatar" alt="" class="w-14 h-14 rounded-xl border border-skynet-border object-cover bg-skynet-black" />
                    <div class="absolute -bottom-1 -right-1 w-3 h-3 @statusDotColor rounded-full border-2 border-skynet-card"></div>
                </div>
                <div class="flex-1 min-w-0">
                    <a asp-page="/Users/Profile" asp-route-steamId="@user.SteamId" class="font-bold truncate block hover:text-skynet-accent transition">@user.PersonaName</a>
                    <p class="text-[10px] text-skynet-muted uppercase tracking-widest">@statusText</p>
                </div>
                @if (isFriend)
                {
                    <form method="post" asp-page-handler="Remove">
                        <input type="hidden" name="TargetSteamId" value="@user.SteamId" />
                        <button type="submit" class="w-10 h-10 rounded-lg bg-red-500/10 text-red-500 border border-red-500/20 flex items-center justify-center hover:bg-red-500 hover:text-white transition" title="Remove friend">
                            <i class="fas fa-user-minus text-xs"></i>
                        </button>
                    </form>
                }
                else if (isIncoming)
                {
                    <form method="post" asp-page-handler="Accept">
                        <input type="hidden" name="TargetSteamId" value="@user.SteamId" />
                        <button type="submit" class="w-10 h-10 rounded-lg bg-skynet-accent/10 text-skynet-accent border border-skynet-accent/20 flex items-center justify-center hover:bg-skynet-accent hover:text-white transition" title="Accept request">
                            <i class="fas fa-user-check text-xs"></i>
                        </button>
                    </form>
                }
                else if (isOutgoing)
                {
                    <div class="w-10 h-10 rounded-lg bg-yellow-500/10 text-yellow-500 border border-yellow-500/20 flex items-center justify-center" title="Request sent">
                        <i class="fas fa-clock text-xs"></i>
                    </div>
                }
                else
                {
                    <form method="post" asp-page-handler="Request">
                        <input type="hidden" name="TargetSteamId" value="@user.SteamId" />
                        <button type="submit" class="w-10 h-10 rounded-lg bg-skynet-accent/10 text-skynet-accent border border-skynet-accent/20 flex items-center justify-center hover:bg-skynet-accent hover:text-white transition" title="Add friend">
                            <i class="fas fa-user-plus text-xs"></i>
                        </button>
                    </form>
                }
            </article>
        }
    </div>
</div>

<script>
    function filterUsers(term) {
        var t = term.toLowerCase();
        var cards = document.querySelectorAll('article[data-user]');
        cards.forEach(function(card) {
            var name = (card.getAttribute('data-user') || '').toLowerCase();
            card.style.display = !t || name.indexOf(t) >= 0 ? '' : 'none';
        });
    }
</script>
