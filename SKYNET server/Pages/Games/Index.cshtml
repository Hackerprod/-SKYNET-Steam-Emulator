@page "/games"
@model SKYNET_server.Pages.Games.IndexModel

<div class="space-y-8">
    <header class="relative overflow-hidden rounded-2xl border border-skynet-border bg-skynet-card p-8">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(59,130,246,0.08),transparent_70%)] z-0"></div>
        <div class="relative z-10 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
            <div class="space-y-3">
                <span class="text-[10px] px-2.5 py-1 rounded-full font-black bg-skynet-accent/10 text-skynet-accent border border-skynet-accent/30 uppercase tracking-[0.2em]">Library</span>
                <h1 class="text-4xl font-black text-white leading-tight">Your game collection.</h1>
                <p class="max-w-2xl text-skynet-muted text-sm leading-relaxed">Explore your installed titles, track your achievement progress and play hours synchronized with the server.</p>
            </div>
            <div class="flex flex-wrap gap-2">
                @foreach (var filter in new[] { "All", "Installed", "Playing", "Cloud" })
                {
                    <button class="px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all @(filter == "All" ? "bg-skynet-accent text-white" : "bg-skynet-dark text-skynet-muted border border-skynet-border hover:text-white")">
                        @filter
                    </button>
                }
            </div>
        </div>
    </header>

    <div class="grid gap-6 md:grid-cols-2">
        @foreach (var game in Model.Games)
        {
            <article class="group relative overflow-hidden rounded-2xl border border-skynet-border bg-skynet-card hover:border-skynet-accent/50 hover:-translate-y-1 transition-all duration-300">
                <div class="p-6 relative z-10">
                    <div class="flex items-start justify-between mb-4">
                        <div>
                            <span class="text-[9px] font-black text-skynet-muted uppercase tracking-widest">@game.Genre</span>
                            <h2 class="text-2xl font-black text-white mt-1 group-hover:text-skynet-accent transition-colors">@game.Name</h2>
                        </div>
                        <span class="text-[9px] px-2 py-1 rounded bg-skynet-black text-skynet-accent border border-skynet-accent/30 font-bold uppercase tracking-widest">@game.Status</span>
                    </div>

                    <p class="text-sm text-skynet-muted leading-relaxed line-clamp-2 mb-6">@game.Description</p>

                    <div class="grid grid-cols-3 gap-3 mb-6">
                        <div class="p-3 rounded-xl bg-skynet-black border border-skynet-border">
                            <p class="text-[9px] font-black text-skynet-muted uppercase tracking-widest">Hours</p>
                            <p class="text-lg font-black text-white mt-1">@game.HoursPlayed h</p>
                        </div>
                        <div class="p-3 rounded-xl bg-skynet-black border border-skynet-border">
                            <p class="text-[9px] font-black text-skynet-muted uppercase tracking-widest">Achievements</p>
                            <p class="text-lg font-black text-white mt-1">@game.AchievementsUnlocked/@game.TotalAchievements</p>
                        </div>
                        <div class="p-3 rounded-xl bg-skynet-black border border-skynet-border">
                            <p class="text-[9px] font-black text-skynet-muted uppercase tracking-widest">Progress</p>
                            <p class="text-lg font-black text-white mt-1">@game.Progress%</p>
                        </div>
                    </div>

                    <div class="space-y-2">
                        <div class="flex items-center justify-between text-[10px] font-black uppercase tracking-widest">
                            <span class="text-skynet-muted">Campaign Synchronization</span>
                            <span class="text-skynet-accent">@game.Progress%</span>
                        </div>
                        <div class="h-2 rounded-full bg-skynet-dark overflow-hidden">
                            <div class="h-full bg-skynet-accent transition-all duration-1000" style="width: @game.Progress%"></div>
                        </div>
                    </div>
                </div>
            </article>
        }
    </div>
</div>
