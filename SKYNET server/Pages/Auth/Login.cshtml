@page "/login"
@model SKYNET_server.Pages.Auth.LoginModel
@{
    ViewData["UseAppShell"] = false;
}

<div class="flex min-h-screen items-center justify-center bg-zinc-950 px-4 py-10">
    <section class="w-full max-w-md rounded-lg border border-zinc-800 bg-zinc-900 p-6 shadow-xl">
        <div class="mb-6">
            <p class="text-[10px] font-black uppercase tracking-[0.22em] text-cyan-400">SKYNET Server</p>
            <h1 class="mt-2 text-2xl font-black text-white">Login</h1>
            <p class="mt-2 text-sm text-zinc-500">Admin inicial: Hackerprod / Steam2026. Puedes cambiarlo desde el panel admin.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="mb-4 rounded-lg border border-red-500/40 bg-red-500/10 px-4 py-3 text-sm font-semibold text-red-100">@Model.ErrorMessage</div>
        }

        <form method="post" class="space-y-4">
            <div>
                <label asp-for="Username" class="mb-2 block text-[10px] font-black uppercase tracking-widest text-zinc-500">Usuario</label>
                <input asp-for="Username" autocomplete="username" class="w-full rounded-lg border-zinc-700 bg-zinc-950 text-white focus:border-cyan-500 focus:ring-cyan-500" />
            </div>
            <div>
                <label asp-for="Password" class="mb-2 block text-[10px] font-black uppercase tracking-widest text-zinc-500">Password</label>
                <input asp-for="Password" type="password" autocomplete="current-password" class="w-full rounded-lg border-zinc-700 bg-zinc-950 text-white focus:border-cyan-500 focus:ring-cyan-500" />
            </div>
            <label class="flex items-center gap-3 rounded-lg border border-zinc-800 bg-zinc-950 px-3 py-3 text-sm font-semibold text-zinc-300">
                <input asp-for="RememberMe" class="rounded border-zinc-700 bg-zinc-900 text-cyan-500 focus:ring-cyan-500" />
                Recordar sesion por 30 dias
            </label>
            <button class="w-full rounded-lg bg-cyan-600 px-4 py-3 text-xs font-black uppercase tracking-widest text-white hover:bg-cyan-500">Entrar</button>
        </form>

        <div class="mt-5 flex items-center justify-between text-sm">
            <a asp-page="/Auth/Register" class="font-semibold text-cyan-400 hover:text-cyan-300">Crear usuario</a>
            <a asp-page="/Index" class="text-zinc-500 hover:text-zinc-300">Dashboard</a>
        </div>
    </section>
</div>
