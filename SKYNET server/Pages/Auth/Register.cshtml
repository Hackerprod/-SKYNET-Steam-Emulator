@page "/register"
@model SKYNET_server.Pages.Auth.RegisterModel
@using SKYNET_server.Services
@inject SteamUiMockService SteamUiService
@{
    var snapshot = SteamUiService.GetSnapshot();
}

<div class="mx-auto grid min-h-[92vh] max-w-7xl items-center gap-6 lg:grid-cols-[0.95fr_1.05fr] py-8">
    <section class="rounded-3xl border border-zinc-800/60 bg-zinc-900/95 p-8 shadow-2xl md:p-10 backdrop-blur-xl relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(168,85,247,0.05),transparent_70%)]"></div>
        <div class="relative z-10">
            <div class="space-y-4 mb-8">
                <span class="text-[10px] px-2.5 py-1 rounded-full font-black bg-purple-500/10 text-purple-500 border border-purple-500/30 uppercase tracking-[0.2em]">Create Profile</span>
                <h1 class="text-4xl font-black tracking-tight text-white leading-tight">Set up your profile.</h1>
                <p class="text-zinc-400 text-sm leading-relaxed">Registration designed as launcher start: visible name, social preference and entry point to your collection.</p>
            </div>

            <form class="space-y-6">
                <div class="grid gap-5 md:grid-cols-2">
                    <div class="space-y-2">
                        <label class="block text-[10px] font-black uppercase tracking-widest text-zinc-500 ml-1">Display Name</label>
                        <input type="text" placeholder="Hackerprod" class="w-full rounded-xl border border-zinc-800/60 bg-zinc-950/60 px-5 py-4 text-sm text-white placeholder:text-zinc-600 focus:border-purple-500/50 focus:ring-0 transition-colors" />
                    </div>
                    <div class="space-y-2">
                        <label class="block text-[10px] font-black uppercase tracking-widest text-zinc-500 ml-1">Username</label>
                        <input type="text" placeholder="skynet.user" class="w-full rounded-xl border border-zinc-800/60 bg-zinc-950/60 px-5 py-4 text-sm text-white placeholder:text-zinc-600 focus:border-purple-500/50 focus:ring-0 transition-colors" />
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="block text-[10px] font-black uppercase tracking-widest text-zinc-500 ml-1">Email</label>
                    <input type="email" placeholder="hackerprod@skynet.gg" class="w-full rounded-xl border border-zinc-800/60 bg-zinc-950/60 px-5 py-4 text-sm text-white placeholder:text-zinc-600 focus:border-purple-500/50 focus:ring-0 transition-colors" />
                </div>

                <div class="grid gap-5 md:grid-cols-2">
                    <div class="space-y-2">
                        <label class="block text-[10px] font-black uppercase tracking-widest text-zinc-500 ml-1">Password</label>
                        <input type="password" placeholder="••••••••••••" class="w-full rounded-xl border border-zinc-800/60 bg-zinc-950/60 px-5 py-4 text-sm text-white placeholder:text-zinc-600 focus:border-purple-500/50 focus:ring-0 transition-colors" />
                    </div>
                    <div class="space-y-2">
                        <label class="block text-[10px] font-black uppercase tracking-widest text-zinc-500 ml-1">Confirmation</label>
                        <input type="password" placeholder="••••••••••••" class="w-full rounded-xl border border-zinc-800/60 bg-zinc-950/60 px-5 py-4 text-sm text-white placeholder:text-zinc-600 focus:border-purple-500/50 focus:ring-0 transition-colors" />
                    </div>
                </div>

                <div class="p-4 rounded-xl bg-zinc-950/40 border border-zinc-800/60 text-[11px] text-zinc-500 leading-relaxed italic">
                    Initial profile: visible library, social feed, achievement radar and recent sessions panel.
                </div>

                <div class="flex flex-wrap gap-3 pt-2">
                    <button type="button" class="flex-1 py-4 rounded-xl text-[10px] font-black uppercase tracking-widest bg-gradient-to-br from-cyan-500 to-purple-500 text-white shadow-glow-cyan hover:scale-[1.02] transition-transform">
                        Create Account
                    </button>
                    <a asp-page="/Auth/Login" class="px-6 py-4 rounded-xl text-[10px] font-black uppercase tracking-widest bg-zinc-800/60 text-zinc-400 border border-zinc-700/40 hover:text-white transition-colors">
                        Back to Login
                    </a>
                </div>
            </form>
        </div>
    </section>

    <section class="relative overflow-hidden rounded-3xl border border-zinc-800/60 bg-zinc-950/80 p-8 shadow-2xl md:p-12">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(6,182,212,0.15),transparent_40%),radial-gradient(circle_at_bottom_right,rgba(168,85,247,0.15),transparent_40%)]"></div>
        <div class="relative z-10 space-y-10">
            <div class="grid gap-6 md:grid-cols-2">
                <div class="rounded-2xl border border-zinc-800/60 bg-zinc-900/60 p-5 group hover:border-cyan-500/30 transition-colors">
                    <p class="text-[9px] font-black text-zinc-500 uppercase tracking-widest mb-1">Social Layer</p>
                    <p class="text-lg font-black text-white group-hover:text-cyan-500 transition-colors">Parties and Presence</p>
                    <p class="text-[11px] text-zinc-500 mt-2 leading-relaxed">The friends network remains always visible with focus on active games.</p>
                </div>
                <div class="rounded-2xl border border-zinc-800/60 bg-zinc-900/60 p-5 group hover:border-purple-500/30 transition-colors">
                    <p class="text-[9px] font-black text-zinc-500 uppercase tracking-widest mb-1">Progress Layer</p>
                    <p class="text-lg font-black text-white group-hover:text-purple-500 transition-colors">Achievement Rarity</p>
                    <p class="text-[11px] text-zinc-500 mt-2 leading-relaxed">Each game shows progress, completion and recent unlocks.</p>
                </div>
            </div>

            <div class="rounded-2xl border border-zinc-800/60 bg-gradient-to-br from-cyan-500/10 via-zinc-950 to-purple-500/10 p-8 relative overflow-hidden group">
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(6,182,212,0.1),transparent_70%)] opacity-0 group-hover:opacity-100 transition-opacity"></div>
                <div class="relative z-10">
                    <span class="text-[9px] font-black text-zinc-500 uppercase tracking-widest mb-2 block">Preview</span>
                    <h2 class="text-3xl font-black text-white leading-tight mb-8">Visual dashboard of library and achievements.</h2>
                    <div class="grid grid-cols-3 gap-4">
                        <div class="p-4 rounded-xl bg-zinc-950/80 border border-zinc-800/60 text-center">
                            <p class="text-2xl font-black text-white">@snapshot.Games.Count</p>
                            <p class="text-[9px] text-zinc-500 font-bold uppercase mt-1">Games</p>
                        </div>
                        <div class="p-4 rounded-xl bg-zinc-950/80 border border-zinc-800/60 text-center">
                            <p class="text-2xl font-black text-white">@snapshot.Achievements.Count</p>
                            <p class="text-[9px] text-zinc-500 font-bold uppercase mt-1">Achievements</p>
                        </div>
                        <div class="p-4 rounded-xl bg-zinc-950/80 border border-zinc-800/60 text-center">
                            <p class="text-2xl font-black text-white">@snapshot.Friends.Count.ToString("D2")</p>
                            <p class="text-[9px] text-zinc-500 font-bold uppercase mt-1">Friends</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
