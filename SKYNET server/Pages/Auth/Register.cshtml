@page "/register"
@model SKYNET_server.Pages.Auth.RegisterModel
@{
    ViewData["UseAppShell"] = false;
}

<div class="flex min-h-screen items-center justify-center bg-zinc-950 px-4 py-10">
    <section class="w-full max-w-xl rounded-lg border border-zinc-800 bg-zinc-900 p-6 shadow-xl">
        <div class="mb-6">
            <p class="text-[10px] font-black uppercase tracking-[0.22em] text-cyan-400">Nuevo perfil</p>
            <h1 class="mt-2 text-2xl font-black text-white">Registro</h1>
            <p class="mt-2 text-sm text-zinc-500">Crea una cuenta web y un SteamID local persistente para el emulador.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="mb-4 rounded-lg border border-red-500/40 bg-red-500/10 px-4 py-3 text-sm font-semibold text-red-100">@Model.ErrorMessage</div>
        }

        <form method="post" class="space-y-4">
            <div class="grid gap-4 md:grid-cols-2">
                <div>
                    <label asp-for="Username" class="mb-2 block text-[10px] font-black uppercase tracking-widest text-zinc-500">Usuario</label>
                    <input asp-for="Username" autocomplete="username" class="w-full rounded-lg border-zinc-700 bg-zinc-950 text-white focus:border-cyan-500 focus:ring-cyan-500" />
                </div>
                <div>
                    <label asp-for="PersonaName" class="mb-2 block text-[10px] font-black uppercase tracking-widest text-zinc-500">Nombre visible</label>
                    <input asp-for="PersonaName" class="w-full rounded-lg border-zinc-700 bg-zinc-950 text-white focus:border-cyan-500 focus:ring-cyan-500" />
                </div>
            </div>
            <div class="grid gap-4 md:grid-cols-2">
                <div>
                    <label asp-for="Password" class="mb-2 block text-[10px] font-black uppercase tracking-widest text-zinc-500">Password</label>
                    <input asp-for="Password" type="password" autocomplete="new-password" class="w-full rounded-lg border-zinc-700 bg-zinc-950 text-white focus:border-cyan-500 focus:ring-cyan-500" />
                </div>
                <div>
                    <label asp-for="ConfirmPassword" class="mb-2 block text-[10px] font-black uppercase tracking-widest text-zinc-500">Confirmar</label>
                    <input asp-for="ConfirmPassword" type="password" autocomplete="new-password" class="w-full rounded-lg border-zinc-700 bg-zinc-950 text-white focus:border-cyan-500 focus:ring-cyan-500" />
                </div>
            </div>
            <button class="w-full rounded-lg bg-cyan-600 px-4 py-3 text-xs font-black uppercase tracking-widest text-white hover:bg-cyan-500">Crear cuenta</button>
        </form>

        <div class="mt-5 text-sm">
            <a asp-page="/Auth/Login" class="font-semibold text-cyan-400 hover:text-cyan-300">Volver al login</a>
        </div>
    </section>
</div>
