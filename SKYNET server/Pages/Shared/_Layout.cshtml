@using SKYNET_server.Services
@inject SteamUiMockService SteamUiService
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    var useAppShell = ViewData["UseAppShell"] as bool? ?? true;
    var snapshot = SteamUiService.GetSnapshot();
    Func<string, string> navClass = prefix => currentPage.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)
        ? "border-cyan-300/30 bg-cyan-400/10 text-cyan-100 shadow-lg shadow-cyan-950/20"
        : "border-white/5 bg-white/[0.03] text-slate-300 hover:border-white/10 hover:bg-white/[0.05] hover:text-white";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SKYNET server</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif']
                    },
                    colors: {
                        zinc: {
                            950: '#09090b'
                        }
                    },
                    boxShadow: {
                        'glow-cyan': '0 0 20px rgba(6,182,212,0.3)',
                        'glow-purple': '0 0 20px rgba(168,85,247,0.3)',
                        'inner-cyan': 'inset 0 0 0 1px rgba(6,182,212,0.25)'
                    }
                }
            }
        };
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SKYNET_server.styles.css" asp-append-version="true" />
</head>
<body class="bg-zinc-950 text-white antialiased min-h-screen selection:bg-cyan-500/30 selection:text-white">
    @* Fondo con Grid y Brillos de UI.txt *@
    <div class="fixed inset-0 pointer-events-none" style="background-image:linear-gradient(rgba(6,182,212,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(6,182,212,0.04) 1px,transparent 1px); background-size:48px 48px; z-index:0;"></div>
    <div class="fixed pointer-events-none" style="top:-20%; left:-10%; width:500px; height:500px; background:radial-gradient(circle,rgba(6,182,212,0.08) 0%,transparent 70%); z-index:0;"></div>
    <div class="fixed pointer-events-none" style="bottom:-20%; right:-10%; width:500px; height:500px; background:radial-gradient(circle,rgba(168,85,247,0.08) 0%,transparent 70%); z-index:0;"></div>

    @if (useAppShell)
    {
        <div class="relative flex h-screen overflow-hidden z-10">
            @* SIDEBAR *@
            <aside class="hidden lg:flex flex-col w-64 border-r border-zinc-800/60 bg-zinc-950/95 backdrop-blur-3xl shrink-0">
                <div class="flex items-center gap-3 px-5 py-5 border-b border-zinc-800/60">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center bg-gradient-to-br from-[#06b6d4] to-[#a855f7] shadow-glow-cyan">
                        <span class="text-white font-black text-lg">SK</span>
                    </div>
                    <div>
                        <h1 class="font-black text-white text-lg leading-none tracking-tight">SKYNET</h1>
                        <p class="text-[10px] text-zinc-500 mt-1 uppercase tracking-widest">Steam Server</p>
                    </div>
                </div>

                <nav class="flex-1 py-4 px-3 space-y-1 overflow-y-auto">
                    <a asp-page="/Index" class="flex items-center justify-between px-3 py-3 rounded-xl text-sm font-medium transition-all @(currentPage == "/Index" ? "text-white bg-gradient-to-br from-cyan-500/20 to-purple-500/20 shadow-inner-cyan" : "text-zinc-400 hover:text-white hover:bg-zinc-800/50")">
                        <span class="flex items-center gap-3">Dashboard</span>
                        <span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-gradient-to-br from-cyan-500 to-purple-500 text-white">@snapshot.Metrics.Count</span>
                    </a>
                    <a asp-page="/Games/Index" class="flex items-center justify-between px-3 py-3 rounded-xl text-sm font-medium transition-all @(currentPage.StartsWith("/Games") ? "text-white bg-gradient-to-br from-cyan-500/20 to-purple-500/20 shadow-inner-cyan" : "text-zinc-400 hover:text-white hover:bg-zinc-800/50")">
                        <span>Games</span>
                        <span class="text-xs text-zinc-500">@snapshot.Games.Count</span>
                    </a>
                    <a asp-page="/Friends/Index" class="flex items-center justify-between px-3 py-3 rounded-xl text-sm font-medium transition-all @(currentPage.StartsWith("/Friends") ? "text-white bg-gradient-to-br from-cyan-500/20 to-purple-500/20 shadow-inner-cyan" : "text-zinc-400 hover:text-white hover:bg-zinc-800/50")">
                        <span>Friends</span>
                        <span class="text-xs text-zinc-500">@snapshot.Friends.Count</span>
                    </a>
                    <a asp-page="/Achievements/Index" class="flex items-center justify-between px-3 py-3 rounded-xl text-sm font-medium transition-all @(currentPage.StartsWith("/Achievements") ? "text-white bg-gradient-to-br from-cyan-500/20 to-purple-500/20 shadow-inner-cyan" : "text-zinc-400 hover:text-white hover:bg-zinc-800/50")">
                        <span>Achievements</span>
                        <span class="text-xs text-zinc-500">@snapshot.Achievements.Count</span>
                    </a>
                </nav>

                <div class="px-4 py-4 border-t border-zinc-800/60">
                    <div class="flex items-center gap-3">
                        <div class="relative shrink-0">
                            <div class="w-10 h-10 rounded-full bg-zinc-800 border-2 border-cyan-500 flex items-center justify-center text-xs font-bold">@snapshot.Profile.DisplayName[0]</div>
                            <span class="absolute bottom-0 right-0 w-3 h-3 bg-green-400 rounded-full border-2 border-zinc-950"></span>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-bold text-white truncate">@snapshot.Profile.DisplayName</p>
                            <p class="text-[10px] text-zinc-500 uppercase">Lv. @snapshot.Profile.Level · @snapshot.Profile.Status</p>
                        </div>
                    </div>
                </div>
            </aside>

            @* MAIN CONTENT AREA *@
            <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
                <header class="flex items-center justify-between px-6 py-4 border-b border-zinc-800/60 bg-zinc-950/80 backdrop-blur-xl">
                    <div class="flex items-center gap-4">
                        <p class="text-xs font-black uppercase tracking-[0.2em] text-zinc-500">@ViewData["Title"]</p>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="hidden sm:flex items-center gap-2 bg-zinc-800/60 border border-zinc-700/40 rounded-xl px-4 py-2 text-xs font-bold text-zinc-300">
                            <span class="w-2 h-2 rounded-full bg-green-500"></span> @snapshot.Profile.Status
                        </div>
                        <a asp-page="/Auth/Login" class="px-4 py-2 rounded-xl text-xs font-bold bg-gradient-to-br from-cyan-500 to-purple-500 text-white shadow-glow-cyan hover:scale-105 transition-transform">
                            Session Control
                        </a>
                    </div>
                </header>

                <main class="flex-1 overflow-y-auto p-6 space-y-6">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <main class="relative z-10 min-h-screen">
            @RenderBody()
        </main>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
