@using SKYNET_server.Services
@inject SteamApiStateService SteamState
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    var useAppShell = ViewData["UseAppShell"] as bool? ?? true;
    var token = Context.Request.Cookies[SteamApiStateService.WebSessionCookieName];
    var currentUser = SteamState.GetWebUser(token);
    var isAdmin = SteamState.IsWebAdmin(token);
    var snapshot = SteamState.GetWebSnapshot(token);
    var incomingFriendRequests = currentUser == null ? 0 : SteamState.GetIncomingFriendRequests(token ?? string.Empty).Count;
    var initial = string.IsNullOrWhiteSpace(snapshot.Profile.DisplayName) ? "U" : snapshot.Profile.DisplayName[..1].ToUpperInvariant();
    Func<string, string> navClass = prefix => currentPage.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)
        ? "text-skynet-accent bg-skynet-accent/5"
        : "text-skynet-muted hover:text-white hover:bg-white/5";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SKYNETEMU</title>
    <link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="~/js/CallHelper.js" asp-append-version="true"></script>
    <script>
        var _snTimer = null;
        var _snConfirmCb = null;
        var _snConfirmResolve = null;

        function showToast(msg, type) {
            type = type || 'info';
            var el = document.getElementById('snToast');
            if (!el) return;
            var icon = document.getElementById('snToastIcon');
            var msgEl = document.getElementById('snToastMsg');
            clearTimeout(_snTimer);
            el.classList.add('hidden');
            el.querySelector('div').classList.remove('animate-sn-out');
            msgEl.textContent = msg;
            icon.className = 'w-8 h-8 rounded-lg flex items-center justify-center shrink-0 text-sm';
            if (type === 'success') {
                icon.classList.add('bg-green-500/10', 'text-green-500', 'border', 'border-green-500/20');
                icon.innerHTML = '<i class="fas fa-check"></i>';
            } else if (type === 'error') {
                icon.classList.add('bg-red-500/10', 'text-red-500', 'border', 'border-red-500/20');
                icon.innerHTML = '<i class="fas fa-times"></i>';
            } else if (type === 'warning') {
                icon.classList.add('bg-yellow-500/10', 'text-yellow-500', 'border', 'border-yellow-500/20');
                icon.innerHTML = '<i class="fas fa-exclamation"></i>';
            } else {
                icon.classList.add('bg-skynet-accent/10', 'text-skynet-accent', 'border', 'border-skynet-accent/20');
                icon.innerHTML = '<i class="fas fa-info"></i>';
            }
            el.classList.remove('hidden');
            _snTimer = setTimeout(hideToast, 4000);
        }

        function hideToast() {
            var el = document.getElementById('snToast');
            el.querySelector('div').classList.add('animate-sn-out');
            setTimeout(function () { el.classList.add('hidden'); el.querySelector('div').classList.remove('animate-sn-out'); }, 200);
        }

        function showConfirm(title, msg, btnText, btnClass, cb) {
            _snConfirmCb = cb || null;
            document.getElementById('snConfirmTitle').textContent = title;
            document.getElementById('snConfirmMsg').textContent = msg;
            var btn = document.getElementById('snConfirmBtn');
            btn.textContent = btnText || 'Confirm';
            btn.className = 'rounded-lg px-5 py-2.5 text-xs font-black uppercase tracking-widest transition ' + (btnClass || 'bg-red-500 text-white hover:bg-red-600');
            document.getElementById('snConfirm').classList.remove('hidden');
        }

        function acceptConfirm() {
            document.getElementById('snConfirm').classList.add('hidden');
            if (_snConfirmCb) _snConfirmCb();
            if (_snConfirmResolve) { _snConfirmResolve(true); _snConfirmResolve = null; }
        }

        function cancelConfirm() {
            document.getElementById('snConfirm').classList.add('hidden');
            _snConfirmCb = null;
            if (_snConfirmResolve) { _snConfirmResolve(false); _snConfirmResolve = null; }
        }

        function confirmAsync(title, msg, btnText, btnClass) {
            return new Promise(function (resolve) {
                _snConfirmResolve = resolve;
                showConfirm(title, msg, btnText, btnClass, function () { resolve(true); });
            });
        }

        function onAjaxComplete(data) {
            showToast(data.message, data.success ? 'success' : 'error');
            if (data.success) {
                setTimeout(function () { location.reload(); }, 800);
            }
        }

        function openMobileNav() {
            var el = document.getElementById('snMobileNav');
            if (!el) return;
            el.classList.remove('hidden');
            requestAnimationFrame(function () {
                document.getElementById('snMobileNavPanel').classList.remove('translate-x-full');
            });
        }

        function closeMobileNav() {
            var el = document.getElementById('snMobileNav');
            if (!el) return;
            var panel = document.getElementById('snMobileNavPanel');
            panel.classList.add('translate-x-full');
            setTimeout(function () { el.classList.add('hidden'); }, 300);
        }

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') { cancelConfirm(); closeMobileNav(); }
        });
    </script>
</head>
<body class="flex flex-col h-[100dvh] overflow-hidden bg-skynet-black text-gray-200 antialiased">
    @if (useAppShell)
    {
        <!-- Header -->
        <header class="h-16 bg-skynet-black border-b border-skynet-border flex items-center justify-between px-4 md:px-8 z-20 shrink-0">
            <div class="flex items-center md:space-x-12">
                <a asp-page="/Index" class="flex items-center space-x-3">
                    <div class="w-8 h-8 bg-white rounded flex items-center justify-center">
                        <i class="fas fa-microchip text-skynet-black text-lg"></i>
                    </div>
                    <span class="font-bold tracking-tighter text-lg">SKYNET<span class="text-skynet-accent">EMU</span></span>
                </a>
                <nav class="hidden md:flex space-x-1 h-16">
                    <a asp-page="/Index" class="nav-link flex items-center px-4 text-xs font-bold uppercase tracking-widest @navClass("/Index")">Dashboard</a>
                    <a asp-page="/Users/Index" class="nav-link flex items-center px-4 text-xs font-bold uppercase tracking-widest @navClass("/Users")">Users</a>
                    <a asp-page="/Games/Index" class="nav-link flex items-center px-4 text-xs font-bold uppercase tracking-widest @navClass("/Games")">Games</a>
                    <a asp-page="/Achievements/Index" class="nav-link flex items-center px-4 text-xs font-bold uppercase tracking-widest @navClass("/Achievements")">Stats</a>
                    @if (isAdmin)
                    {
                        <a asp-page="/Admin/Index" class="nav-link flex items-center px-4 text-xs font-bold uppercase tracking-widest @navClass("/Admin")">Admin</a>
                    }
                </nav>
            </div>
            <div class="flex items-center space-x-6">
                @if (currentUser == null)
                {
                    <a asp-page="/Auth/Login" class="bg-white text-skynet-black font-bold py-2 px-4 rounded-lg text-xs uppercase tracking-widest hover:bg-gray-200 transition-all duration-200">Login</a>
                }
                else
                {
                    <div class="text-right hidden md:block">
                        <p class="text-xs font-bold">@snapshot.Profile.DisplayName</p>
                        <p class="text-[10px] text-skynet-muted uppercase tracking-widest">Online</p>
                    </div>
                    <a asp-page="/Auth/Logout" class="hidden md:flex w-10 h-10 rounded-lg border border-skynet-border bg-skynet-card items-center justify-center text-skynet-muted hover:text-white hover:border-skynet-accent transition-all" title="Sign out">
                        <i class="fas fa-right-from-bracket text-sm"></i>
                    </a>
                }
                <button type="button" onclick="openMobileNav()" class="md:hidden w-10 h-10 rounded-lg border border-skynet-border bg-skynet-card flex items-center justify-center text-skynet-muted hover:text-white hover:border-skynet-accent transition-all" aria-label="Open menu">
                    <i class="fas fa-bars text-sm"></i>
                </button>
            </div>
        </header>

        <!-- Main -->
        <main class="flex-1 overflow-y-auto p-8">
            <div class="max-w-7xl mx-auto space-y-8">
                @RenderBody()
            </div>
        </main>

        <!-- Footer -->
        <footer class="h-8 bg-skynet-black border-t border-skynet-border flex items-center justify-between px-4 sm:px-6 text-[10px] text-skynet-muted uppercase tracking-[0.2em] shrink-0">
            <div class="flex items-center space-x-4">
                <span>SKYNET_OS_v2.0</span>
                <span class="text-green-500">&#9679; GC_CONNECTED</span>
            </div>
            <span class="hidden sm:inline">SKYNET_NETWORK_ENCRYPTION_ACTIVE</span>
        </footer>

        <!-- Mobile sidenav -->
        <div id="snMobileNav" class="fixed inset-0 z-[105] hidden md:hidden">
            <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeMobileNav()"></div>
            <div id="snMobileNavPanel" class="absolute right-0 top-0 h-full w-72 max-w-[80%] bg-skynet-card border-l border-skynet-border flex flex-col transform translate-x-full transition-transform duration-300 ease-out">
                <div class="h-16 flex items-center justify-between px-5 border-b border-skynet-border shrink-0">
                    <span class="font-bold tracking-tighter text-lg">SKYNET<span class="text-skynet-accent">EMU</span></span>
                    <button type="button" onclick="closeMobileNav()" class="w-9 h-9 rounded-lg border border-skynet-border flex items-center justify-center text-skynet-muted hover:text-white hover:border-skynet-accent transition-all" aria-label="Close menu">
                        <i class="fas fa-times text-sm"></i>
                    </button>
                </div>
                <nav class="flex-1 overflow-y-auto p-3 space-y-1">
                    <a asp-page="/Index" onclick="closeMobileNav()" class="flex items-center px-4 py-3 rounded-lg text-xs font-bold uppercase tracking-widest @navClass("/Index")">Dashboard</a>
                    <a asp-page="/Users/Index" onclick="closeMobileNav()" class="flex items-center px-4 py-3 rounded-lg text-xs font-bold uppercase tracking-widest @navClass("/Users")">Users</a>
                    <a asp-page="/Games/Index" onclick="closeMobileNav()" class="flex items-center px-4 py-3 rounded-lg text-xs font-bold uppercase tracking-widest @navClass("/Games")">Games</a>
                    <a asp-page="/Achievements/Index" onclick="closeMobileNav()" class="flex items-center px-4 py-3 rounded-lg text-xs font-bold uppercase tracking-widest @navClass("/Achievements")">Stats</a>
                    @if (isAdmin)
                    {
                        <a asp-page="/Admin/Index" onclick="closeMobileNav()" class="flex items-center px-4 py-3 rounded-lg text-xs font-bold uppercase tracking-widest @navClass("/Admin")">Admin</a>
                    }
                </nav>
                <div class="p-3 border-t border-skynet-border shrink-0">
                    @if (currentUser == null)
                    {
                        <a asp-page="/Auth/Login" onclick="closeMobileNav()" class="block text-center bg-white text-skynet-black font-bold py-3 px-4 rounded-lg text-xs uppercase tracking-widest hover:bg-gray-200 transition-all">Login</a>
                    }
                    else
                    {
                        <div class="flex items-center justify-between gap-3">
                            <div class="min-w-0">
                                <p class="text-xs font-bold truncate">@snapshot.Profile.DisplayName</p>
                                <p class="text-[10px] text-skynet-muted uppercase tracking-widest">Online</p>
                            </div>
                            <a asp-page="/Auth/Logout" class="w-10 h-10 rounded-lg border border-skynet-border flex items-center justify-center text-skynet-muted hover:text-white hover:border-skynet-accent transition-all shrink-0" title="Sign out">
                                <i class="fas fa-right-from-bracket text-sm"></i>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <main class="min-h-screen">
            @RenderBody()
        </main>
    }

    @await RenderSectionAsync("Scripts", required: false)

    <!-- Global Toast + Confirm -->
    <div id="snToast" class="fixed top-6 right-6 z-[100] hidden max-w-sm w-full pointer-events-none">
        <div class="rounded-xl border border-skynet-border bg-skynet-card shadow-2xl p-4 flex items-start gap-3 pointer-events-auto animate-sn-in">
            <div id="snToastIcon" class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0 text-sm"></div>
            <p id="snToastMsg" class="text-sm font-semibold text-white flex-1 pt-1"></p>
            <button onclick="hideToast()" class="text-skynet-muted hover:text-white transition text-xs pt-1"><i class="fas fa-times"></i></button>
        </div>
    </div>

    <div id="snConfirm" class="fixed inset-0 z-[110] hidden">
        <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="cancelConfirm()"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md px-4">
            <div class="rounded-2xl border border-skynet-border bg-skynet-card p-6 shadow-2xl">
                <div class="flex items-center gap-3 mb-4">
                    <div id="snConfirmIcon" class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0"></div>
                    <h3 id="snConfirmTitle" class="text-lg font-black text-white"></h3>
                </div>
                <p id="snConfirmMsg" class="text-sm text-skynet-muted mb-6"></p>
                <div class="flex gap-3 justify-end">
                    <button onclick="cancelConfirm()" class="rounded-lg border border-skynet-border px-5 py-2.5 text-xs font-bold uppercase tracking-widest text-skynet-muted hover:text-white hover:border-skynet-accent transition">Cancel</button>
                    <button id="snConfirmBtn" onclick="acceptConfirm()" class="rounded-lg px-5 py-2.5 text-xs font-black uppercase tracking-widest transition"></button>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
