@using SKYNET_server.Services
@inject SteamApiStateService SteamState
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    var useAppShell = ViewData["UseAppShell"] as bool? ?? true;
    var token = Context.Request.Cookies[SteamApiStateService.WebSessionCookieName];
    var currentUser = SteamState.GetWebUser(token);
    var isAdmin = SteamState.IsWebAdmin(token);
    var snapshot = SteamState.GetWebSnapshot(token);
    var incomingFriendRequests = currentUser == null ? 0 : SteamState.GetIncomingFriendRequests(token ?? string.Empty).Count;
    var initial = string.IsNullOrWhiteSpace(snapshot.Profile.DisplayName) ? "U" : snapshot.Profile.DisplayName[..1].ToUpperInvariant();
    Func<string, string> navClass = prefix => currentPage.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)
        ? "border-cyan-500 bg-cyan-500/10 text-white"
        : "border-zinc-800 bg-zinc-950 text-zinc-400 hover:border-zinc-700 hover:text-white";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SKYNET server</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: { zinc: { 950: '#09090b' } }
                }
            }
        };
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SKYNET_server.styles.css" asp-append-version="true" />
</head>
<body class="min-h-screen bg-zinc-950 text-zinc-100 antialiased">
    @if (useAppShell)
    {
        <div class="flex min-h-screen">
            <aside class="hidden w-72 shrink-0 border-r border-zinc-800 bg-zinc-950 lg:flex lg:flex-col">
                <div class="border-b border-zinc-800 px-5 py-5">
                    <div class="flex items-center gap-3">
                        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-cyan-600 text-sm font-black text-white">SK</div>
                        <div>
                            <h1 class="text-lg font-black leading-none">SKYNET</h1>
                            <p class="mt-1 text-[10px] font-bold uppercase tracking-widest text-zinc-500">Steam Emulator</p>
                        </div>
                    </div>
                </div>

                <nav class="flex-1 space-y-2 p-4">
                    <a asp-page="/Index" class="flex items-center justify-between rounded-lg border px-3 py-3 text-sm font-bold transition @navClass("/Index")">
                        <span>Dashboard</span>
                        <span class="text-xs text-zinc-500">@snapshot.Metrics.Count</span>
                    </a>
                    <a asp-page="/Friends/Index" class="flex items-center justify-between rounded-lg border px-3 py-3 text-sm font-bold transition @navClass("/Friends")">
                        <span>Amigos</span>
                        <span class="text-xs text-zinc-500">@snapshot.Friends.Count</span>
                    </a>
                    <a asp-page="/Users/Index" class="flex items-center justify-between rounded-lg border px-3 py-3 text-sm font-bold transition @navClass("/Users")">
                        <span>Users</span>
                        <span class="text-xs @(incomingFriendRequests > 0 ? "text-cyan-400" : "text-zinc-500")">@(incomingFriendRequests > 0 ? incomingFriendRequests : snapshot.Profile.LibraryCount)</span>
                    </a>
                    <a asp-page="/Games/Index" class="flex items-center justify-between rounded-lg border px-3 py-3 text-sm font-bold transition @navClass("/Games")">
                        <span>Juegos</span>
                        <span class="text-xs text-zinc-500">@snapshot.Games.Count</span>
                    </a>
                    <a asp-page="/Achievements/Index" class="flex items-center justify-between rounded-lg border px-3 py-3 text-sm font-bold transition @navClass("/Achievements")">
                        <span>Stats</span>
                        <span class="text-xs text-zinc-500">@snapshot.Achievements.Count</span>
                    </a>
                    @if (isAdmin)
                    {
                        <a asp-page="/Admin/Index" class="flex items-center justify-between rounded-lg border px-3 py-3 text-sm font-bold transition @navClass("/Admin")">
                            <span>Admin</span>
                            <span class="text-xs text-cyan-400">root</span>
                        </a>
                    }
                </nav>

                <div class="border-t border-zinc-800 p-4">
                    <div class="flex items-center gap-3 rounded-lg border border-zinc-800 bg-zinc-900 p-3">
                        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-zinc-800 text-sm font-black">@initial</div>
                        <div class="min-w-0 flex-1">
                            <p class="truncate text-sm font-bold text-white">@snapshot.Profile.DisplayName</p>
                            <p class="text-[10px] uppercase tracking-widest text-zinc-500">@snapshot.Profile.Status</p>
                        </div>
                    </div>
                </div>
            </aside>

            <div class="flex min-w-0 flex-1 flex-col">
                <header class="flex items-center justify-between border-b border-zinc-800 bg-zinc-950/95 px-5 py-4">
                    <div>
                        <p class="text-[10px] font-black uppercase tracking-[0.22em] text-zinc-500">@ViewData["Title"]</p>
                        <p class="mt-1 text-sm text-zinc-400">Estado persistente local del emulador.</p>
                    </div>
                    <div class="flex items-center gap-2">
                        @if (currentUser == null)
                        {
                            <a asp-page="/Auth/Login" class="rounded-lg bg-cyan-600 px-4 py-2 text-xs font-black uppercase tracking-widest text-white hover:bg-cyan-500">Login</a>
                        }
                        else
                        {
                            <a asp-page="/Auth/Logout" class="rounded-lg border border-zinc-700 px-4 py-2 text-xs font-black uppercase tracking-widest text-zinc-300 hover:text-white">Logout</a>
                        }
                    </div>
                </header>
                <main class="flex-1 overflow-y-auto p-5">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <main class="min-h-screen">
            @RenderBody()
        </main>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
