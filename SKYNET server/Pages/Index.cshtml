@page
@model IndexModel

<div class="space-y-5">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="rounded-lg border border-cyan-500/40 bg-cyan-500/10 px-4 py-3 text-sm font-semibold text-cyan-100">@Model.StatusMessage</div>
    }

    <section class="grid gap-4 xl:grid-cols-[1.2fr_0.8fr]">
        <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
            <div class="flex flex-col gap-5 xl:flex-row xl:items-start xl:justify-between">
                <div class="flex min-w-0 items-start gap-4">
                    <img src="/api/users/@Model.CurrentUser.SteamId/avatar?v=@DateTimeOffset.UtcNow.ToUnixTimeSeconds()" alt="" class="h-20 w-20 shrink-0 rounded-lg border border-zinc-700 bg-zinc-950 object-cover" />
                    <div class="min-w-0">
                        <p class="text-[10px] font-black uppercase tracking-[0.22em] text-cyan-400">Sesion activa</p>
                        <h1 class="mt-2 truncate text-3xl font-black text-white">@Model.CurrentUser.PersonaName</h1>
                        <p class="mt-2 text-sm text-zinc-400">SteamID @Model.CurrentUser.SteamId - Account @Model.CurrentUser.AccountId - App @Model.CurrentUser.AppId</p>
                    </div>
                </div>
                <div class="grid w-full gap-3 xl:w-[30rem]">
                    <form method="post" asp-page-handler="Persona" class="flex w-full gap-2">
                        <input asp-for="PersonaName" class="min-w-0 flex-1 rounded-lg border-zinc-700 bg-zinc-950 text-sm text-white focus:border-cyan-500 focus:ring-cyan-500" />
                        <button class="rounded-lg bg-cyan-600 px-4 py-2 text-xs font-black uppercase tracking-widest text-white hover:bg-cyan-500">Guardar</button>
                    </form>
                    <form method="post" asp-page-handler="Avatar" enctype="multipart/form-data" class="grid gap-2 md:grid-cols-[1fr_auto]">
                        <input asp-for="AvatarFile" type="file" accept="image/*" class="min-w-0 rounded-lg border border-zinc-700 bg-zinc-950 text-sm text-zinc-200 file:mr-3 file:border-0 file:bg-zinc-800 file:px-3 file:py-2 file:text-xs file:font-black file:uppercase file:tracking-widest file:text-zinc-100 hover:file:bg-zinc-700" />
                        <button class="rounded-lg border border-cyan-500 bg-cyan-500/10 px-4 py-2 text-xs font-black uppercase tracking-widest text-cyan-100 hover:bg-cyan-500/20">Avatar</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
            @foreach (var metric in Model.Snapshot.Metrics)
            {
                <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-4">
                    <p class="text-[10px] font-black uppercase tracking-widest text-zinc-500">@metric.Label</p>
                    <p class="mt-2 text-2xl font-black text-white">@metric.Value</p>
                    <p class="mt-1 text-xs text-zinc-500">@metric.Detail</p>
                </div>
            }
        </div>
    </section>

    @if (Model.IncomingFriendRequests.Count > 0 || Model.OutgoingFriendRequests.Count > 0)
    {
        <section class="grid gap-5 xl:grid-cols-2">
            <div class="rounded-lg border border-cyan-500/30 bg-cyan-500/10">
                <div class="border-b border-cyan-500/20 px-5 py-4">
                    <h2 class="text-lg font-black text-white">Solicitudes recibidas</h2>
                    <p class="text-xs text-cyan-100/70">Estas tambien se publican por eventos para la DLL.</p>
                </div>
                <div class="divide-y divide-cyan-500/20">
                    @if (Model.IncomingFriendRequests.Count == 0)
                    {
                        <p class="px-5 py-5 text-sm text-cyan-100/60">No hay solicitudes entrantes.</p>
                    }
                    @foreach (var request in Model.IncomingFriendRequests)
                    {
                        <article class="flex flex-col gap-3 px-5 py-4 md:flex-row md:items-center md:justify-between">
                            <div class="flex min-w-0 items-center gap-3">
                                <img src="/api/users/@request.FromUser.SteamId/avatar" alt="" class="h-11 w-11 rounded-lg border border-cyan-500/30 bg-zinc-950 object-cover" />
                                <div class="min-w-0">
                                    <a asp-page="/Users/Profile" asp-route-steamId="@request.FromUser.SteamId" class="truncate text-sm font-black text-white hover:text-cyan-200">@request.FromUser.PersonaName</a>
                                    <p class="text-xs text-cyan-100/60">SteamID @request.FromUser.SteamId</p>
                                </div>
                            </div>
                            <div class="flex gap-2">
                                <form method="post" asp-page-handler="AcceptFriend">
                                    <input type="hidden" name="RequestId" value="@request.Id" />
                                    <button class="rounded-lg bg-cyan-600 px-3 py-2 text-[10px] font-black uppercase tracking-widest text-white hover:bg-cyan-500">Aceptar</button>
                                </form>
                                <form method="post" asp-page-handler="DeclineFriend">
                                    <input type="hidden" name="RequestId" value="@request.Id" />
                                    <button class="rounded-lg border border-red-500/30 px-3 py-2 text-[10px] font-black uppercase tracking-widest text-red-200 hover:bg-red-500/10">Rechazar</button>
                                </form>
                            </div>
                        </article>
                    }
                </div>
            </div>

            <div class="rounded-lg border border-zinc-800 bg-zinc-900">
                <div class="border-b border-zinc-800 px-5 py-4">
                    <h2 class="text-lg font-black text-white">Solicitudes enviadas</h2>
                    <p class="text-xs text-zinc-500">Pendientes de respuesta del otro usuario.</p>
                </div>
                <div class="divide-y divide-zinc-800">
                    @if (Model.OutgoingFriendRequests.Count == 0)
                    {
                        <p class="px-5 py-5 text-sm text-zinc-500">No hay solicitudes salientes.</p>
                    }
                    @foreach (var request in Model.OutgoingFriendRequests)
                    {
                        <article class="flex flex-col gap-3 px-5 py-4 md:flex-row md:items-center md:justify-between">
                            <div class="flex min-w-0 items-center gap-3">
                                <img src="/api/users/@request.ToUser.SteamId/avatar" alt="" class="h-11 w-11 rounded-lg border border-zinc-700 bg-zinc-950 object-cover" />
                                <div class="min-w-0">
                                    <a asp-page="/Users/Profile" asp-route-steamId="@request.ToUser.SteamId" class="truncate text-sm font-black text-white hover:text-cyan-300">@request.ToUser.PersonaName</a>
                                    <p class="text-xs text-zinc-500">SteamID @request.ToUser.SteamId</p>
                                </div>
                            </div>
                            <form method="post" asp-page-handler="CancelFriend">
                                <input type="hidden" name="RequestId" value="@request.Id" />
                                <button class="rounded-lg border border-zinc-700 px-3 py-2 text-[10px] font-black uppercase tracking-widest text-zinc-300 hover:text-white">Cancelar</button>
                            </form>
                        </article>
                    }
                </div>
            </div>
        </section>
    }

    <section class="grid gap-5 xl:grid-cols-[1fr_0.9fr]">
        <div class="rounded-lg border border-zinc-800 bg-zinc-900">
            <div class="flex items-center justify-between border-b border-zinc-800 px-5 py-4">
                <div>
                    <h2 class="text-lg font-black text-white">Stats</h2>
                    <p class="text-xs text-zinc-500">Persisten en el backend y tambien las puede actualizar Dota.</p>
                </div>
            </div>
            <div class="divide-y divide-zinc-800">
                @if (Model.Stats.Stats.Count == 0)
                {
                    <p class="px-5 py-6 text-sm text-zinc-500">No hay stats guardados.</p>
                }
                @foreach (var stat in Model.Stats.Stats.OrderBy(s => s.Name))
                {
                    <div class="flex items-center justify-between px-5 py-3">
                        <span class="text-sm font-semibold text-zinc-200">@stat.Name</span>
                        <span class="font-mono text-sm text-cyan-300">@stat.Data</span>
                    </div>
                }
            </div>
            <form method="post" asp-page-handler="Stat" class="grid gap-3 border-t border-zinc-800 p-5 md:grid-cols-[1fr_140px_auto]">
                <input asp-for="StatName" placeholder="wins" class="rounded-lg border-zinc-700 bg-zinc-950 text-sm text-white focus:border-cyan-500 focus:ring-cyan-500" />
                <input asp-for="StatValue" type="number" min="0" class="rounded-lg border-zinc-700 bg-zinc-950 text-sm text-white focus:border-cyan-500 focus:ring-cyan-500" />
                <button class="rounded-lg border border-cyan-500 bg-cyan-500/10 px-4 py-2 text-xs font-black uppercase tracking-widest text-cyan-100 hover:bg-cyan-500/20">Actualizar</button>
            </form>
        </div>

        <div class="rounded-lg border border-zinc-800 bg-zinc-900">
            <div class="border-b border-zinc-800 px-5 py-4">
                <h2 class="text-lg font-black text-white">Actividad</h2>
                <p class="text-xs text-zinc-500">Resumen generado desde el estado real del server.</p>
            </div>
            <div class="divide-y divide-zinc-800">
                @foreach (var item in Model.Snapshot.Activities)
                {
                    <div class="px-5 py-4">
                        <p class="text-sm font-bold text-white">@item.Title</p>
                        <p class="mt-1 text-xs text-zinc-500">@item.Description</p>
                        <p class="mt-2 text-[10px] font-black uppercase tracking-widest text-cyan-500">@item.When</p>
                    </div>
                }
            </div>
        </div>
    </section>

    <section class="rounded-lg border border-zinc-800 bg-zinc-900">
        <div class="border-b border-zinc-800 px-5 py-4">
            <h2 class="text-lg font-black text-white">Achievements</h2>
        </div>
        <div class="grid gap-3 p-5 md:grid-cols-2 xl:grid-cols-3">
            @if (Model.Snapshot.Achievements.Count == 0)
            {
                <p class="text-sm text-zinc-500">No hay achievements guardados.</p>
            }
            @foreach (var achievement in Model.Snapshot.Achievements)
            {
                <article class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
                    <div class="flex items-center justify-between gap-3">
                        <h3 class="truncate text-sm font-bold text-white">@achievement.Title</h3>
                        <span class="rounded border border-zinc-700 px-2 py-1 text-[10px] font-black uppercase text-zinc-400">@achievement.Rarity</span>
                    </div>
                    <div class="mt-3 h-1.5 rounded bg-zinc-800">
                        <div class="h-1.5 rounded bg-cyan-500" style="width:@achievement.Progress%"></div>
                    </div>
                </article>
            }
        </div>
    </section>
</div>
