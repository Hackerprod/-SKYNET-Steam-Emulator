@page
@model IndexModel

<div class="space-y-6">
    <div class="grid gap-6 xl:grid-cols-[1.5fr_1fr]">
        
        <div class="space-y-6">
            <section class="relative overflow-hidden rounded-2xl border border-zinc-800/60 bg-zinc-900/40 shadow-2xl shadow-black/50" style="height: 320px;">
                <div class="absolute inset-0 bg-gradient-to-r from-zinc-950 via-zinc-950/70 to-transparent z-10"></div>
                <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/80 to-transparent z-10"></div>
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(6,182,212,0.15),transparent_70%)] z-10"></div>
                
                <div class="absolute inset-0 w-full h-full bg-zinc-800 animate-pulse"></div>

                <div class="absolute inset-0 z-20 flex flex-col justify-end p-8">
                    <div class="flex items-center gap-2 mb-3">
                        <span class="text-[10px] px-2.5 py-1 rounded-full font-bold border bg-green-500/10 text-green-500 border-green-500/30 uppercase tracking-widest">
                            ● @Model.Snapshot.FeaturedGame.Status
                        </span>
                        <span class="text-xs text-zinc-400 font-medium">@Model.Snapshot.FeaturedGame.Name</span>
                    </div>
                    <h2 class="text-4xl font-black text-white mb-2 leading-none">@Model.Snapshot.FeaturedGame.Name</h2>
                    <p class="text-zinc-400 text-sm mb-6 max-w-md line-clamp-2">@Model.Snapshot.FeaturedGame.Description</p>
                    
                    <div class="flex items-center gap-4">
                        <button class="flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-bold text-white bg-gradient-to-br from-cyan-500 to-purple-500 shadow-glow-cyan hover:scale-105 transition-transform">
                            Play Now
                        </button>
                        <div class="px-4 py-2 rounded-xl border border-zinc-800/60 bg-zinc-950/80 backdrop-blur">
                            <p class="text-lg font-black text-white leading-none">@Model.Snapshot.FeaturedGame.HoursPlayed h</p>
                            <p class="text-[10px] text-zinc-500 uppercase font-bold mt-1">Playtime</p>
                        </div>
                    </div>
                </div>
            </section>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                @foreach (var metric in Model.Snapshot.Metrics)
                {
                    <div class="rounded-2xl p-5 border border-zinc-800/60 bg-zinc-900/90 relative overflow-hidden group hover:-translate-y-1 transition-all duration-300">
                        <div class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_20%_20%,rgba(6,182,212,0.12)_0%,transparent_60%)]"></div>
                        <div class="relative">
                            <div class="flex items-center justify-between mb-3">
                                <div class="w-10 h-10 rounded-xl flex items-center justify-center bg-cyan-500/10 border border-cyan-500/30 text-cyan-500 shadow-glow-cyan">
                                    <span class="text-xs font-bold">@metric.Label[0]</span>
                                </div>
                            </div>
                            <p class="text-2xl font-black text-white">@metric.Value</p>
                            <p class="text-[10px] text-zinc-500 mt-1 uppercase font-bold tracking-widest">@metric.Label</p>
                            <p class="text-[10px] mt-1 font-bold text-cyan-400">@metric.Detail</p>
                        </div>
                    </div>
                }
            </div>
        </div>

        <aside class="space-y-6">
            <section class="rounded-2xl border border-zinc-800/60 bg-zinc-900/80 backdrop-blur-xl p-6 shadow-xl">
                <div class="flex items-center justify-between mb-6">
                    <div>
                        <h3 class="font-black text-white text-lg">Achievement Radar</h3>
                        <p class="text-[10px] text-zinc-500 uppercase font-bold tracking-widest mt-1">Latest Unlocks</p>
                    </div>
                    <span class="text-[10px] px-2.5 py-1 rounded-full bg-amber-500/10 text-amber-500 border border-amber-500/30 font-bold uppercase tracking-widest">
                        @Model.Snapshot.Achievements.Count Total
                    </span>
                </div>
                <div class="space-y-3">
                    @foreach (var achievement in Model.Snapshot.Achievements.Take(3))
                    {
                        <div class="flex items-center gap-4 p-4 rounded-xl border border-zinc-800/60 bg-zinc-950/40 group hover:bg-zinc-800/40 transition-colors">
                            <div class="w-12 h-12 rounded-xl bg-amber-500/10 border border-amber-500/30 flex items-center justify-center text-xl shadow-glow-purple">
                                🏆
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-bold text-white truncate">@achievement.Title</p>
                                <p class="text-[10px] text-zinc-500 uppercase font-bold tracking-wider mt-0.5">@achievement.Game</p>
                            </div>
                            <span class="text-[9px] font-black text-amber-500 uppercase px-2 py-0.5 rounded-md bg-amber-500/10">@achievement.Rarity</span>
                        </div>
                    }
                </div>
            </section>

            <section class="rounded-2xl border border-zinc-800/60 bg-gradient-to-br from-cyan-500/5 via-zinc-950 to-purple-500/5 p-6 border-l-4 border-l-cyan-500">
                <div class="flex items-center gap-3 mb-4">
                    <span class="w-2 h-2 rounded-full bg-cyan-500 animate-pulse"></span>
                    <p class="text-[10px] text-zinc-400 uppercase font-black tracking-widest">Live Feed</p>
                </div>
                <div class="space-y-4">
                    @foreach (var item in Model.Snapshot.Activities.Take(3))
                    {
                        <div class="relative pl-4 border-l border-zinc-800/60">
                            <div class="absolute -left-[4.5px] top-0 w-2 h-2 rounded-full bg-zinc-800 border border-zinc-700"></div>
                            <p class="text-xs font-bold text-white">@item.Title</p>
                            <p class="text-[10px] text-zinc-500 mt-1">@item.Description</p>
                            <p class="text-[9px] font-black text-cyan-600 uppercase mt-1 tracking-widest">@item.When</p>
                        </div>
                    }
                </div>
            </section>
        </aside>
    </div>

    <section>
        <div class="flex items-center justify-between mb-6">
            <div>
                <h3 class="font-black text-white text-2xl">My Library</h3>
                <p class="text-[10px] text-zinc-500 uppercase font-bold tracking-widest mt-1">@Model.Snapshot.Games.Count Games Installed</p>
            </div>
            <button class="text-[10px] font-black text-cyan-500 uppercase tracking-widest hover:text-cyan-400 transition-colors">View All →</button>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            @foreach (var game in Model.Snapshot.Games.Take(3))
            {
                <article class="group relative overflow-hidden rounded-2xl border border-zinc-800/60 bg-zinc-900/60 hover:border-cyan-500/50 hover:-translate-y-1 transition-all duration-300">
                    <div class="h-32 bg-zinc-800 relative overflow-hidden">
                        <div class="absolute inset-0 bg-gradient-to-t from-zinc-900 to-transparent"></div>
                        <div class="absolute bottom-3 left-4">
                            <span class="text-[9px] px-2 py-0.5 rounded bg-zinc-950/80 text-zinc-400 font-bold uppercase tracking-widest">@game.Genre</span>
                        </div>
                    </div>
                    <div class="p-5">
                        <h4 class="text-lg font-black text-white group-hover:text-cyan-400 transition-colors">@game.Name</h4>
                        <div class="flex items-center justify-between mt-4">
                            <div class="flex flex-col">
                                <span class="text-xl font-black text-white">@game.HoursPlayed h</span>
                                <span class="text-[9px] text-zinc-500 uppercase font-bold">Played</span>
                            </div>
                            <div class="text-right flex flex-col">
                                <span class="text-xs font-bold text-cyan-500">@game.AchievementsUnlocked/@game.TotalAchievements</span>
                                <span class="text-[9px] text-zinc-500 uppercase font-bold">Achievements</span>
                            </div>
                        </div>
                        <div class="mt-4 h-1.5 rounded-full bg-zinc-800 overflow-hidden">
                            <div class="h-full bg-gradient-to-r from-cyan-500 to-purple-500" style="width: @game.Progress%"></div>
                        </div>
                    </div>
                </article>
            }
        </div>
    </section>
</div>
