<Window x:Class="SKYNET.Client.Views.GameSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game settings" Height="640" Width="560"
        WindowStyle="None" ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{StaticResource SkynetBlack}" Foreground="{StaticResource SkynetText}"
        FontFamily="{StaticResource SkynetFont}" UseLayoutRounding="True">

    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="Foreground" Value="{StaticResource SkynetMuted}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,14,0,5" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource SkynetText}" />
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource SkynetBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{StaticResource SkynetBlack}" BorderBrush="{StaticResource SkynetBorder}"
                    BorderThickness="0,0,0,1" MouseLeftButtonDown="Bar_Drag">
                <Grid Margin="18,0">
                    <TextBlock Text="GAME SETTINGS" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" />
                    <Button Content="&#x2715;" Click="Cancel_Click" HorizontalAlignment="Right" Width="32" Height="28"
                            Background="Transparent" Foreground="{StaticResource SkynetMuted}" BorderThickness="0"
                            FontSize="13" Cursor="Hand" />
                </Grid>
            </Border>

            <!-- Body -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="22,6,22,6">
                <StackPanel>
                    <TextBlock Text="DISPLAY NAME" Style="{StaticResource Label}" Margin="0,6,0,5" />
                    <TextBox x:Name="TName" Style="{StaticResource Field}" />

                    <TextBlock Text="EXECUTABLE" Style="{StaticResource Label}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TExe" Style="{StaticResource Field}" IsReadOnly="True" Foreground="{StaticResource SkynetMuted}" />
                        <Button Grid.Column="1" Content="CHANGE" Style="{StaticResource GhostButton}" Click="ChangeExe_Click" Margin="8,0,0,0" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="APP ID" Style="{StaticResource Label}" />
                            <TextBox x:Name="TAppId" Style="{StaticResource Field}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ARCHITECTURE" Style="{StaticResource Label}" />
                            <ComboBox x:Name="TArch" Height="36" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="LAUNCH ARGUMENTS" Style="{StaticResource Label}" />
                    <TextBox x:Name="TArgs" Style="{StaticResource Field}" />

                    <Border Height="1" Background="{StaticResource SkynetBorder}" Margin="0,20,0,4" />
                    <TextBlock Text="EMULATOR (steam_api.ini)" FontWeight="Bold" FontSize="12" Margin="0,10,0,0" />

                    <TextBlock Text="SERVER URL" Style="{StaticResource Label}" />
                    <TextBox x:Name="TServerUrl" Style="{StaticResource Field}" />

                    <TextBlock Text="LANGUAGE" Style="{StaticResource Label}" />
                    <TextBox x:Name="TLanguage" Style="{StaticResource Field}" />

                    <CheckBox x:Name="CSecure" Content="Secure networking (SDR certificate)" />
                    <CheckBox x:Name="CServerApi" Content="Use dedicated server API" />
                    <CheckBox x:Name="CActiveWeb" Content="Use the active web user" />
                    <CheckBox x:Name="CUnlockDlc" Content="Unlock all DLC" />
                    <CheckBox x:Name="CInventory" Content="Enable inventory" />
                    <CheckBox x:Name="CLogFile" Content="Write log file" />
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource SkynetBlack}" BorderBrush="{StaticResource SkynetBorder}"
                    BorderThickness="0,1,0,0" Padding="18,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="LAUNCH NOW" Style="{StaticResource GhostButton}" Click="Launch_Click" Margin="0,0,10,0" />
                    <Button Content="CANCEL" Style="{StaticResource GhostButton}" Click="Cancel_Click" Margin="0,0,10,0" />
                    <Button Content="SAVE" Style="{StaticResource AccentButton}" Click="Save_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
