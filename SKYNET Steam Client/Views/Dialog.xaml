<Window x:Class="SKYNET.Client.Views.Dialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        SizeToContent="Height" Width="420" Background="Transparent" AllowsTransparency="True"
        Foreground="{StaticResource SkynetText}" FontFamily="{StaticResource SkynetFont}">
    <Border Background="{StaticResource SkynetCard}" BorderBrush="{StaticResource SkynetBorder}"
            BorderThickness="1" CornerRadius="12" Padding="24" MouseLeftButtonDown="Root_Drag">
        <StackPanel>
            <TextBlock x:Name="TitleText" FontWeight="Bold" FontSize="15" Foreground="{StaticResource SkynetText}" />
            <TextBlock x:Name="MessageText" Foreground="{StaticResource SkynetMuted}" FontSize="13"
                       TextWrapping="Wrap" Margin="0,10,0,0" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                <Button x:Name="CancelBtn" Content="CANCEL" Style="{StaticResource GhostButton}"
                        Click="Cancel_Click" Margin="0,0,10,0" />
                <Button x:Name="OkBtn" Content="OK" Style="{StaticResource AccentButton}" Click="Ok_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
